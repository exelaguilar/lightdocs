APP_ENV=production
# Optional deployment paths. Leave blank/unset for project-local development.
# Packaged installs use /var/lib/lightdocs as the site root and /etc for config.
LIGHTDOCS_SITE_DIR=
LIGHTDOCS_STATE_DIR=
LIGHTDOCS_CONTENT_DIR=
LIGHTDOCS_UPLOAD_DIR=
DOCS_NAME=Lightdocs
DOCS_TAGLINE="Documentation without the framework tax."
DOCS_BASE_URL=https://docs.example.com

# The installer generates this administrator password when left empty.
DOCS_ADMIN_PASSWORD=

DOCS_GITHUB_URL=

DOCS_ACCENT=#7c3aed
