APP_ENV=production
# Optional deployment paths. Leave blank/unset for project-local development.
# Packaged installs use /var/lib/lightdocs as the site root and /etc for config.
LIGHTDOCS_SITE_DIR=
LIGHTDOCS_STATE_DIR=
LIGHTDOCS_CONTENT_DIR=
LIGHTDOCS_UPLOAD_DIR=
# Set true to serve the last published bundles while rejecting web/worker rebuilds.
LIGHTDOCS_ASSET_READ_ONLY=false
DOCS_NAME=Lightdocs
DOCS_TAGLINE="Documentation without the framework tax."
DOCS_BASE_URL=https://docs.example.com

# Set this before the first request on a fresh local install. Native and Docker
# installers generate a password when one is not supplied.
DOCS_ADMIN_PASSWORD=

DOCS_GITHUB_URL=

DOCS_ACCENT=#7c3aed

# Extension ZIPs remain compatible with unsigned local packages by default.
# Set require_signature and provide a JSON signer-to-PEM map to lock down installs.
LIGHTDOCS_EXTENSION_TRUST_MODE=allow_unsigned
LIGHTDOCS_EXTENSION_TRUSTED_SIGNERS={}
