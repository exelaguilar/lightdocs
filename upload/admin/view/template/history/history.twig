{{ header | raw }}
<main
  class="mx-auto grid w-[min(calc(100%-3rem),82rem)] gap-6 py-7 pb-10 text-sm max-[900px]:w-[min(calc(100%-2rem),82rem)] max-[640px]:gap-5 max-[640px]:py-5"
>
  <nav
    class="flex items-center gap-2 text-xs text-muted-foreground"
    aria-label="Breadcrumb"
  >
    <a class="transition-colors hover:text-foreground" href="/admin"
      >Workspace</a
    ><svg
      class="h-3.5 w-3.5"
      viewBox="0 0 24 24"
      aria-hidden="true"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <path d="m9 18 6-6-6-6" /></svg
    ><span class="font-medium text-foreground">History</span>
  </nav>
  <header
    class="flex items-end justify-between gap-4 max-[640px]:items-stretch max-[640px]:flex-col"
  >
    <div>
      <p
        class="m-0 text-xs font-semibold uppercase tracking-[0.08em] text-muted-foreground"
      >
        Local-first version control
      </p>
      <h1
        class="m-[0.2rem_0_0.3rem] text-2xl font-semibold tracking-[-0.025em]"
      >
        Local Git history
      </h1>
      <p class="max-w-2xl text-sm leading-6 text-muted-foreground">
        Review application changes and create private local snapshots without a
        remote server or network access.
      </p>
    </div>
    <a
      class="inline-flex min-h-9 items-center justify-center gap-2 rounded-md border border-border bg-card px-3.5 py-2 text-sm font-semibold text-foreground shadow-sm hover:bg-accent hover:text-accent-foreground"
      href="/admin/extensions/local_git/settings"
      >Git settings</a
    >
  </header>
  {% if message %}
  <div
    class="rounded-lg border border-border bg-card px-4 py-3 text-sm"
    role="status"
  >
    {{ message }}
  </div>
  {% endif %} {% if error %}
  <div
    class="rounded-lg border border-destructive/40 bg-destructive/10 px-4 py-3 text-sm text-destructive"
    role="alert"
  >
    {{ error }}
  </div>
  {% endif %} {% if history['state'] == 'disabled' or history['state'] ==
  'unavailable' %}
  <section
    class="flex flex-col items-center justify-center gap-3 rounded-xl border border-dashed border-border bg-card px-6 py-14 text-center shadow-sm"
  >
    <div
      class="flex size-10 items-center justify-center rounded-full bg-muted text-muted-foreground"
    >
      <svg class="size-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="1.8"
          d="M12 8v4l2.5 2.5M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"
        />
      </svg>
    </div>
    <h2 class="text-base font-semibold">
      {{ history['state'] == 'disabled' ? 'Local Git is disabled' : 'The Git
      executable is unavailable' }}
    </h2>
    <p class="max-w-lg text-sm leading-6 text-muted-foreground">
      {{ history['state'] == 'disabled' ? 'Enable the Local Git extension to
      review changes and create local snapshots.' : 'Install the git package in
      the LXC. No Git server, account, SSH key, or daemon is required.' }}
    </p>
    {% if history['state'] == 'disabled' %}<a
      class="mt-1 inline-flex min-h-9 items-center rounded-md border border-primary bg-primary px-3.5 py-2 text-sm font-semibold text-primary-foreground hover:bg-primary/90"
      href="/admin/extensions/local_git/settings"
      >Open Git settings</a
    >{% endif %}
  </section>
  {% elseif history['state'] == 'not_repository' %}
  <div
    class="grid grid-cols-[minmax(0,1fr)_minmax(16rem,0.45fr)] gap-5 max-[900px]:grid-cols-1"
  >
    <section
      class="grid gap-5 rounded-xl border border-border bg-card p-5 shadow-sm"
    >
      <div>
        <p
          class="text-xs font-semibold uppercase tracking-wide text-muted-foreground"
        >
          Get started
        </p>
        <h2 class="mt-1 text-base font-semibold">
          Create the local repository
        </h2>
        <p class="mt-1 text-sm leading-6 text-muted-foreground">
          This adds only a private <code>.git/</code> directory to the current
          Lightdocs installation.
        </p>
      </div>
      <form
        method="post"
        class="grid grid-cols-2 gap-4 max-[640px]:grid-cols-1"
      >
        <input type="hidden" name="csrf_token" value="{{ csrf }}" /><label
          class="grid gap-1.5 text-xs font-medium text-muted-foreground"
          for="git-author-name"
          >Commit author name<input
            class="min-h-9 rounded-md border border-input bg-card px-2.5 py-2 text-sm text-foreground outline-none focus:border-ring focus:ring-2 focus:ring-ring/20"
            id="git-author-name"
            name="author_name"
            value="Lightdocs Owner"
            required
          /><span class="font-normal leading-5"
            >Saved only in local Git configuration.</span
          ></label
        ><label
          class="grid gap-1.5 text-xs font-medium text-muted-foreground"
          for="git-author-email"
          >Commit author email<input
            class="min-h-9 rounded-md border border-input bg-card px-2.5 py-2 text-sm text-foreground outline-none focus:border-ring focus:ring-2 focus:ring-ring/20"
            id="git-author-email"
            type="email"
            name="author_email"
            value="lightdocs@example.invalid"
            required
          /><span class="font-normal leading-5"
            >Recorded in local commits only.</span
          ></label
        ><button
          class="inline-flex min-h-9 items-center justify-center rounded-md border border-primary bg-primary px-3.5 py-2 text-sm font-semibold text-primary-foreground hover:bg-primary/90"
          name="action"
          value="initialize"
        >
          Initialize Local Git
        </button>
      </form>
    </section>
    <aside
      class="rounded-xl border border-border bg-muted/20 p-5 text-sm leading-6 text-muted-foreground"
    >
      <h2 class="text-sm font-semibold text-foreground">What this does</h2>
      <ol class="mt-3 list-decimal space-y-1 pl-5">
        <li>Runs <code>git init</code> locally.</li>
        <li>Uses the existing <code>.gitignore</code>.</li>
        <li>Leaves files uncommitted for review.</li>
      </ol>
      <p class="mt-4">
        Private Markdown is not ignored. Credentials remain in local history if
        committed.
      </p>
    </aside>
  </div>
  {% else %}
  <section
    class="grid grid-cols-4 overflow-hidden rounded-xl border border-border bg-card shadow-sm max-[760px]:grid-cols-2 max-[480px]:grid-cols-1"
  >
    <div class="px-5 py-4">
      <p class="text-xs text-muted-foreground">Repository</p>
      <strong class="mt-1 block truncate text-sm" title="{{ history['root'] }}"
        >{{ history['root'] }}</strong
      >
    </div>
    <div class="border-l border-border px-5 py-4 max-[480px]:border-l-0">
      <p class="text-xs text-muted-foreground">Branch</p>
      <strong class="mt-1 block text-sm">{{ history['branch'] }}</strong>
    </div>
    <div
      class="border-l border-border px-5 py-4 max-[760px]:border-t max-[480px]:border-l-0"
    >
      <p class="text-xs text-muted-foreground">Working tree</p>
      <strong class="mt-1 block text-sm"
        >{{ history['change_count'] }} change{{ history['change_count'] == 1 ?
        '' : 's' }}</strong
      >
    </div>
    <div
      class="border-l border-border px-5 py-4 max-[760px]:border-t max-[480px]:border-l-0"
    >
      <p class="text-xs text-muted-foreground">Status</p>
      <strong class="mt-1 block text-sm">{{ history['state_label'] }}</strong>
    </div>
  </section>
  <div class="grid grid-cols-2 gap-5 max-[900px]:grid-cols-1">
    <section
      class="overflow-hidden rounded-xl border border-border bg-card shadow-sm"
    >
      <header
        class="flex items-center justify-between border-b border-border px-5 py-4"
      >
        <div>
          <p
            class="text-xs font-semibold uppercase tracking-wide text-muted-foreground"
          >
            Repository history
          </p>
          <h2 class="mt-1 text-base font-semibold">Recent commits</h2>
        </div>
        <span
          class="inline-flex h-6 shrink-0 items-center whitespace-nowrap rounded-full bg-muted px-2.5 py-0 text-[11px] font-medium leading-none text-muted-foreground"
          >{{ history['commit_count'] }} shown</span
        >
      </header>
      <div>
        {% for commit in history['commits'] %}
        <article
          class="flex gap-3 border-b border-border px-5 py-3 last:border-b-0"
        >
          <code
            class="mt-0.5 inline-flex h-6 min-w-[3.25rem] shrink-0 items-center justify-center whitespace-nowrap rounded-md bg-muted px-1.5 py-0 text-[11px] leading-none text-muted-foreground"
            >{{ commit['short'] }}</code
          >
          <div class="min-w-0">
            <strong class="block truncate text-sm font-medium"
              >{{ commit['subject'] }}</strong
            ><small class="text-xs text-muted-foreground"
              >{{ commit['author'] }} &middot; {{ commit['date_label'] }}</small
            >
          </div>
        </article>
        {% endfor %}{% if not history['commits'] %}
        <div class="px-5 py-10 text-center text-sm text-muted-foreground">
          No commits yet. The first commit becomes your local baseline.
        </div>
        {% endif %}
      </div>
    </section>
    <section
      class="overflow-hidden rounded-xl border border-border bg-card shadow-sm"
    >
      <header
        class="flex items-center justify-between border-b border-border px-5 py-4"
      >
        <div>
          <p
            class="text-xs font-semibold uppercase tracking-wide text-muted-foreground"
          >
            Working tree
          </p>
          <h2 class="mt-1 text-base font-semibold">Uncommitted changes</h2>
        </div>
        <span class="text-xs text-muted-foreground"
          >{{ history['change_count'] }} files</span
        >
      </header>
      <div>
        {% for change in history['changes'] %}
        <div
          class="flex items-center gap-3 border-b border-border px-5 py-2.5 last:border-b-0"
        >
          <span
            class="inline-flex min-w-6 justify-center rounded bg-muted px-1.5 py-1 text-[11px] font-bold {{ change['tone_classes'] }}"
            title="Git status {{ change['status'] }}"
            >{{ change['label'] }}</span
          ><span
            class="truncate text-xs text-muted-foreground"
            title="{{ change['path'] }}"
            >{{ change['path'] }}</span
          >
        </div>
        {% endfor %}{% if not history['changes'] %}
        <div class="px-5 py-10 text-center text-sm text-muted-foreground">
          The local working tree is clean.
        </div>
        {% endif %}
      </div>
    </section>
  </div>
  {% if history['changes'] %}
  <section
    class="overflow-hidden rounded-xl border border-border bg-card shadow-sm"
  >
    <header
      class="flex items-start justify-between gap-4 border-b border-border px-5 py-4 max-[640px]:flex-col"
    >
      <div>
        <p
          class="text-xs font-semibold uppercase tracking-wide text-muted-foreground"
        >
          Create snapshot
        </p>
        <h2 class="mt-1 text-base font-semibold">Commit locally</h2>
        <p class="mt-1 text-xs leading-5 text-muted-foreground">
          Snapshot visible application and content changes. This never pushes to
          a remote.
        </p>
      </div>
      <span
        class="rounded-full {{ preflight['replacements'] ? 'bg-destructive/10 text-destructive' : 'bg-muted text-muted-foreground' }} px-2.5 py-1 text-xs font-medium"
        >{{ preflight['replacements'] }} recognized secrets</span
      >
    </header>
    <form method="post" class="grid gap-4 px-5 py-4" data-local-commit-form>
      <input type="hidden" name="csrf_token" value="{{ csrf }}" /><input
        type="hidden"
        name="action"
        value="commit"
      /><label
        class="grid max-w-xl gap-1.5 text-xs font-medium text-muted-foreground"
        for="git-commit-message"
        >Commit message<input
          class="min-h-9 rounded-md border border-input bg-card px-2.5 py-2 text-sm text-foreground outline-none focus:border-ring focus:ring-2 focus:ring-ring/20"
          id="git-commit-message"
          name="message"
          maxlength="180"
          value="Update Lightdocs"
          required /></label
      >{% if preflight['replacements'] %}<label
        class="flex items-start gap-2 rounded-lg border border-amber-300 bg-amber-100 p-3 text-xs leading-5 text-amber-950 dark:border-amber-800 dark:bg-amber-950/50 dark:text-amber-100"
        ><input
          class="mt-0.5 size-4 accent-primary"
          type="checkbox"
          name="acknowledge_secret_history"
          value="1"
          data-commit-ack
        /><span
          >I understand that private Markdown and recognized credentials may
          remain in this LXC's local Git history.</span
        ></label
      >
      <p class="m-0 text-xs text-destructive" data-commit-ack-error hidden>
        Confirm the local credential-history warning before committing.
      </p>
      {% endif %}
      <div class="flex items-center gap-3">
        <button
          class="inline-flex min-h-9 items-center justify-center rounded-md border border-primary bg-primary px-3.5 py-2 text-sm font-semibold text-primary-foreground hover:bg-primary/90"
          type="submit"
          data-local-commit-button
        >
          Commit locally</button
        ><span class="text-xs text-muted-foreground"
          >No remote is configured or contacted.</span
        >
      </div>
    </form>
  </section>
  {% endif %} {% endif %}
</main>
<script nonce="{{ csp_nonce ?? '' }}">
  document
    .querySelector("[data-local-commit-form]")
    ?.addEventListener("submit", (event) => {
      const form = event.currentTarget;
      const ack = form.querySelector("[data-commit-ack]");
      const error = form.querySelector("[data-commit-ack-error]");
      if (ack && !ack.checked) {
        event.preventDefault();
        error.hidden = false;
        ack.focus();
        return;
      }
      if (error) error.hidden = true;
      const button = form.querySelector("[data-local-commit-button]");
      button.disabled = true;
      button.textContent = "Creating local commit&hellip;";
    });
</script>
{{ footer | raw }}
