{{ header | raw }}
<main
  class="mx-auto grid w-[min(calc(100%-3rem),82rem)] gap-6 py-7 pb-10 text-sm max-[900px]:w-[min(calc(100%-2rem),82rem)] max-[640px]:gap-5 max-[640px]:py-5"
>
  <header
    class="flex items-end justify-between gap-6 max-[640px]:items-stretch max-[640px]:flex-col"
  >
    <div class="grid gap-1">
      <nav
        class="flex items-center gap-2 text-xs text-muted-foreground"
        aria-label="Breadcrumb"
      >
        <a class="transition-colors hover:text-foreground" href="/admin"
          >Workspace</a
        ><svg
          class="h-3.5 w-3.5"
          viewBox="0 0 24 24"
          aria-hidden="true"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="m9 18 6-6-6-6" /></svg
        ><span class="text-foreground">Glossary</span>
      </nav>
      <h1 class="m-0 text-2xl font-semibold tracking-[-0.03em] text-foreground">
        Glossary
      </h1>
      <p class="m-0 text-sm leading-6 text-muted-foreground">
        Define shared concepts once, then link to them from ordinary Markdown.
      </p>
    </div>
    <a
      class="inline-flex min-h-9 items-center justify-center gap-2 rounded-md border border-primary bg-primary px-3.5 py-2 text-sm font-semibold leading-5 text-primary-foreground shadow-sm transition-colors hover:bg-primary/90 max-[640px]:w-full"
      href="/admin/glossary/new"
      ><svg
        class="h-4 w-4"
        viewBox="0 0 24 24"
        aria-hidden="true"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="M12 5v14M5 12h14" /></svg
      ><span>Add term</span></a
    >
  </header>
  {% if message %}
  <div
    class="rounded-lg border border-border bg-card px-4 py-3 text-sm text-foreground shadow-sm"
    role="status"
  >
    {{ message }}
  </div>
  {% endif %} {% if error %}
  <div
    class="rounded-lg border border-destructive/40 bg-destructive/10 px-4 py-3 text-sm text-destructive"
    role="alert"
  >
    {{ error }}
  </div>
  {% endif %}
  <section
    class="grid grid-cols-3 divide-x divide-border overflow-hidden rounded-xl border border-border bg-card shadow-sm max-[760px]:grid-cols-1 max-[760px]:divide-x-0 max-[760px]:divide-y max-[640px]:rounded-lg"
    aria-label="Glossary summary"
  >
    <div class="grid gap-1 px-5 py-4 max-[640px]:px-4">
      <span class="text-xs font-medium text-muted-foreground">Terms</span
      ><strong class="text-xl font-semibold tracking-[-0.02em] text-foreground"
        >{{ stats['total'] }}</strong
      ><span class="text-xs text-muted-foreground">Reader definitions</span>
    </div>
    <div class="grid gap-1 px-5 py-4 max-[640px]:px-4">
      <span class="text-xs font-medium text-muted-foreground">Aliases</span
      ><strong class="text-xl font-semibold tracking-[-0.02em] text-foreground"
        >{{ stats['aliases'] }}</strong
      ><span class="text-xs text-muted-foreground">Editor recognizers</span>
    </div>
    <div class="grid gap-1 px-5 py-4 max-[640px]:px-4">
      <span class="text-xs font-medium text-muted-foreground"
        >Definition text</span
      ><strong class="text-xl font-semibold tracking-[-0.02em] text-foreground"
        >{{ stats['characters']|number_format }}</strong
      ><span class="text-xs text-muted-foreground">Characters maintained</span>
    </div>
  </section>
  <section
    class="overflow-hidden rounded-xl border border-border bg-card text-card-foreground shadow-sm max-[640px]:rounded-lg"
  >
    <header
      class="flex items-center justify-between gap-4 border-b border-border px-5 py-4 max-[640px]:px-4"
    >
      <div class="grid gap-0.5">
        <h2 class="m-0 text-base font-semibold tracking-[-0.01em]">
          Glossary terms
        </h2>
        <p class="m-0 text-xs text-muted-foreground">
          Saved in <code>content/_glossary.yaml</code>.
        </p>
      </div>
      <span
        class="hidden rounded-full bg-muted px-2 py-1 text-xs font-medium text-muted-foreground sm:inline-flex"
        >{{ stats['total'] }} total</span
      >
    </header>
    {% if not terms %}
    <div
      class="flex flex-col items-center justify-center gap-2 p-10 text-center text-sm text-muted-foreground"
    >
      <p class="m-0">No terms have been defined yet.</p>
      <a
        class="text-primary underline-offset-4 hover:underline"
        href="/admin/glossary/new"
        >Create the first term</a
      >
    </div>
    {% else %}
    <div
      class="table-toolbar flex justify-end border-b border-border px-5 py-3 max-[640px]:px-4"
    >
      <label class="relative block w-72 max-w-full"
        ><span class="sr-only">Search glossary terms</span
        ><svg
          class="pointer-events-none absolute left-2.5 top-1/2 h-4 w-4 -translate-y-1/2 text-muted-foreground"
          viewBox="0 0 24 24"
          aria-hidden="true"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <circle cx="11" cy="11" r="8" />
          <path d="m21 21-4.3-4.3" /></svg
        ><input
          class="min-h-9 w-full rounded-md border border-input bg-card py-2 pl-8 pr-3 text-xs text-foreground shadow-sm outline-none transition-colors placeholder:text-muted-foreground focus:border-ring focus:ring-2 focus:ring-ring/20"
          type="search"
          placeholder="Search terms..."
          aria-label="Search glossary terms"
          data-table-filter="glossary"
      /></label>
    </div>
    <div class="overflow-x-auto">
      <table
        class="w-full min-w-[54rem] border-collapse text-sm"
        data-table="glossary"
      >
        <thead class="bg-muted/40">
          <tr class="border-b border-border text-left">
            <th
              class="px-5 py-2.5 text-[11px] font-semibold uppercase tracking-wide text-muted-foreground max-[640px]:px-4"
            >
              Term
            </th>
            <th
              class="px-4 py-2.5 text-[11px] font-semibold uppercase tracking-wide text-muted-foreground"
            >
              Definition
            </th>
            <th
              class="px-4 py-2.5 text-[11px] font-semibold uppercase tracking-wide text-muted-foreground"
            >
              Aliases
            </th>
            <th
              class="px-4 py-2.5 text-[11px] font-semibold uppercase tracking-wide text-muted-foreground"
            >
              Target
            </th>
            <th
              class="px-5 py-2.5 text-end text-[11px] font-semibold uppercase tracking-wide text-muted-foreground max-[640px]:px-4"
            >
              Actions
            </th>
          </tr>
        </thead>
        <tbody>
          {% for term in terms %}
          <tr
            class="border-b border-border transition-colors hover:bg-muted/40"
          >
            <td class="px-5 py-3.5 max-[640px]:px-4">
              <div class="flex items-center gap-3">
                <span
                  class="inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-primary/10 text-xs font-semibold text-primary"
                  >{{ term['term']|slice(0, 1)|upper }}</span
                ><strong class="text-sm font-medium text-foreground"
                  >{{ term['term'] }}</strong
                >
              </div>
            </td>
            <td
              class="max-w-[22rem] truncate px-4 py-3.5 text-xs text-muted-foreground"
            >
              {{ term['definition'] }}
            </td>
            <td
              class="max-w-48 truncate px-4 py-3.5 text-xs text-muted-foreground"
            >
              {{ term['aliases'] ? term['aliases']|join(', ') : 'None' }}
            </td>
            <td class="px-4 py-3.5">
              <a
                class="text-xs text-primary hover:underline"
                href="{{ term['url'] }}"
                target="_blank"
                ><code>/glossary#{{ term['slug'] }}</code></a
              >
            </td>
            <td class="px-5 py-3.5 text-end max-[640px]:px-4">
              <div class="flex items-center justify-end gap-1">
                <a
                  aria-label="Edit {{ term['term'] }}"
                  data-tooltip="Edit term"
                  class="inline-flex h-8 w-8 items-center justify-center rounded-md text-muted-foreground transition-colors hover:bg-accent hover:text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring"
                  href="{{ term['edit_url'] }}"
                  ><svg
                    class="h-4 w-4"
                    viewBox="0 0 24 24"
                    aria-hidden="true"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path
                      d="m4 16.5-.8 3.8 3.8-.8L18.5 8a2.1 2.1 0 0 0-3-3L4 16.5Z"
                    />
                    <path d="m14 6 3 3" /></svg
                  ><span class="sr-only">Edit</span></a
                >
                <form
                  method="post"
                  data-confirm="Remove this glossary term? Existing Markdown links will keep working, but no longer show a definition."
                >
                  <input
                    type="hidden"
                    name="csrf_token"
                    value="{{ csrf }}"
                  /><input
                    type="hidden"
                    name="slug"
                    value="{{ term['slug'] }}"
                  /><button
                    aria-label="Remove {{ term['term'] }}"
                    data-tooltip="Remove term"
                    class="inline-flex h-8 w-8 items-center justify-center rounded-md text-muted-foreground transition-colors hover:bg-destructive/10 hover:text-destructive focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring"
                    type="submit"
                  >
                    <svg
                      class="h-4 w-4"
                      viewBox="0 0 24 24"
                      aria-hidden="true"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <path
                        d="M3 6h18M8 6V4h8v2M19 6l-1 15H6L5 6M10 11v6M14 11v6"
                      /></svg
                    ><span class="sr-only">Remove</span>
                  </button>
                </form>
              </div>
            </td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
    {% endif %}
  </section>
</main>
{{ footer | raw }}
