{{ header | raw }}
<main
  class="mx-auto grid w-[min(calc(100%-3rem),90rem)] gap-6 py-6 pb-10 text-sm max-[900px]:w-[min(calc(100%-2rem),90rem)]"
>
  <header
    class="flex items-end justify-between gap-6 max-[640px]:items-stretch max-[640px]:flex-col"
  >
    <div class="grid gap-1">
      <nav
        class="flex items-center gap-2 text-xs text-muted-foreground"
        aria-label="Breadcrumb"
      >
        <a class="transition-colors hover:text-foreground" href="/admin"
          >Workspace</a
        ><svg
          class="h-3.5 w-3.5"
          viewBox="0 0 24 24"
          aria-hidden="true"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="m9 18 6-6-6-6" /></svg
        ><span class="text-foreground">Remote sync</span>
      </nav>
      <h1 class="m-0 text-2xl font-semibold tracking-[-0.03em] text-foreground">
        Remote sync
      </h1>
      <p class="m-0 text-sm leading-6 text-muted-foreground">
        Manually synchronize the private documentation repository with a
        configured Git remote.
      </p>
    </div>
    <a
      class="inline-flex min-h-9 shrink-0 items-center justify-center gap-2 rounded-md border border-border bg-card px-3.5 py-2 text-sm font-semibold leading-5 text-foreground shadow-sm transition-colors hover:bg-accent hover:text-accent-foreground max-[640px]:w-full"
      href="/admin/extensions/remote_sync/settings"
      >Remote sync settings</a
    >
  </header>
  {% if message %}
  <div
    class="rounded-lg border border-border bg-card px-4 py-3 text-sm text-foreground shadow-sm"
    role="status"
  >
    {{ message }}
  </div>
  {% endif %} {% if error %}
  <div
    class="rounded-lg border border-destructive/40 bg-destructive/10 px-4 py-3 text-sm text-destructive"
    role="alert"
  >
    {{ error }}
  </div>
  {% endif %}
  <section
    class="overflow-hidden rounded-xl border border-border bg-card text-card-foreground shadow-sm max-[640px]:rounded-lg"
  >
    <header
      class="flex items-center justify-between gap-4 border-b border-border px-5 py-4 max-[640px]:px-4"
    >
      <div class="grid gap-0.5">
        <p
          class="m-0 text-xs font-semibold uppercase tracking-wide text-muted-foreground"
        >
          Connection status
        </p>
        <h2 class="mt-1 text-base font-semibold tracking-[-0.01em]">
          Repository readiness
        </h2>
      </div>
      <span
        class="inline-flex min-h-6 w-fit items-center justify-center rounded-full px-2 py-0.5 text-xs font-semibold {{ status['available']  and  status['repository']  and  status['configured'] ? 'bg-secondary text-secondary-foreground' : 'bg-muted text-muted-foreground' }}"
        >{{ status['available'] and status['repository'] and
        status['configured'] ? 'Ready' : 'Needs configuration' }}</span
      >
    </header>
    <div
      class="grid grid-cols-[repeat(auto-fit,minmax(9rem,1fr))] gap-3 px-5 py-4 max-[640px]:px-4"
    >
      <div
        class="grid gap-1 rounded-md border border-border bg-muted/30 p-3 text-xs"
      >
        <span class="text-muted-foreground">Git executable</span
        ><strong class="text-foreground"
          >{{ status['available'] ? 'Available' : 'Unavailable' }}</strong
        >
      </div>
      <div
        class="grid gap-1 rounded-md border border-border bg-muted/30 p-3 text-xs"
      >
        <span class="text-muted-foreground">Local repository</span
        ><strong class="text-foreground"
          >{{ status['repository'] ? 'Initialized' : 'Not initialized'
          }}</strong
        >
      </div>
      <div
        class="grid gap-1 rounded-md border border-border bg-muted/30 p-3 text-xs"
      >
        <span class="text-muted-foreground">Remote URL</span
        ><strong class="text-foreground"
          >{{ status['configured'] ? 'Configured' : 'Not configured' }}</strong
        >
      </div>
      <div
        class="grid gap-1 rounded-md border border-border bg-muted/30 p-3 text-xs"
      >
        <span class="text-muted-foreground">Branch</span
        ><strong class="text-foreground">{{ status['branch'] }}</strong>
      </div>
    </div>
  </section>
  <div
    class="grid grid-cols-[minmax(0,1fr)_minmax(16rem,0.36fr)] items-start gap-5 max-[900px]:grid-cols-1"
  >
    <section
      class="overflow-hidden rounded-xl border border-border bg-card text-card-foreground shadow-sm max-[640px]:rounded-lg"
    >
      <header class="border-b border-border px-5 py-4 max-[640px]:px-4">
        <p
          class="m-0 text-xs font-semibold uppercase tracking-wide text-muted-foreground"
        >
          Manual operations
        </p>
        <h2
          class="mt-1 text-base font-semibold tracking-[-0.01em] text-foreground"
        >
          Synchronize repository
        </h2>
        <p class="mt-1 text-xs leading-5 text-muted-foreground">
          Pull only uses fast-forward updates. Push is blocked unless explicitly
          enabled in Remote sync settings.
        </p>
      </header>
      <div class="flex flex-wrap gap-2.5 px-5 py-5 max-[640px]:px-4">
        {% if not status['repository'] %}
        <form method="post">
          <input type="hidden" name="csrf_token" value="{{ csrf }}" /><input
            type="hidden"
            name="action"
            value="initialize"
          /><button
            class="inline-flex min-h-9 items-center justify-center gap-2 rounded-md border border-primary bg-primary px-3.5 py-2 text-sm font-semibold text-primary-foreground shadow-sm transition-colors hover:bg-primary/90"
            type="submit"
          >
            Import remote repository
          </button>
        </form>
        {% endif %}
        <form method="post">
          <input type="hidden" name="csrf_token" value="{{ csrf }}" /><input
            type="hidden"
            name="action"
            value="pull"
          /><button
            class="inline-flex min-h-9 items-center justify-center gap-2 rounded-md border border-primary bg-primary px-3.5 py-2 text-sm font-semibold text-primary-foreground shadow-sm transition-colors hover:bg-primary/90"
            type="submit"
          >
            Pull remote changes
          </button>
        </form>
        <form method="post">
          <input type="hidden" name="csrf_token" value="{{ csrf }}" /><input
            type="hidden"
            name="action"
            value="push"
          /><button
            class="inline-flex min-h-9 items-center justify-center gap-2 rounded-md border border-border bg-card px-3.5 py-2 text-sm font-semibold text-foreground shadow-sm transition-colors hover:bg-accent hover:text-accent-foreground"
            type="submit"
          >
            Push local changes
          </button>
        </form>
      </div>
    </section>
    <aside
      class="grid gap-4 rounded-xl border border-border bg-card p-5 text-card-foreground shadow-sm max-[640px]:rounded-lg"
    >
      <div>
        <p
          class="m-0 text-xs font-semibold uppercase tracking-wide text-muted-foreground"
        >
          Safety notes
        </p>
        <h2
          class="mt-1 text-base font-semibold tracking-[-0.01em] text-foreground"
        >
          Keep deployment changes deliberate
        </h2>
      </div>
      <p class="m-0 text-xs leading-5 text-muted-foreground">
        Remote sync never runs on a timer. Configure the remote URL, branch, and
        credentials from
        <a
          class="text-primary hover:underline"
          href="/admin/extensions/remote_sync/settings"
          >Remote sync settings</a
        >. Initialize Local Git before attempting a pull or push.
      </p>
    </aside>
  </div>
</main>
{{ footer | raw }}
