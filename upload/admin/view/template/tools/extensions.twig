{{ header | raw }}
<main
  class="mx-auto grid w-[min(calc(100%-3rem),82rem)] gap-6 py-7 pb-10 text-sm max-[900px]:w-[min(calc(100%-2rem),82rem)] max-[640px]:gap-5 max-[640px]:py-5"
>
  <header
    class="flex items-end justify-between gap-6 max-[640px]:items-stretch max-[640px]:flex-col"
  >
    <div class="grid gap-1">
      <nav
        class="flex items-center gap-2 text-xs text-muted-foreground"
        aria-label="Breadcrumb"
      >
        <a class="transition-colors hover:text-foreground" href="/admin"
          >Workspace</a
        ><svg
          class="h-3.5 w-3.5"
          viewBox="0 0 24 24"
          aria-hidden="true"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="m9 18 6-6-6-6" /></svg
        ><span class="text-foreground">Extensions</span>
      </nav>
      <h1 class="m-0 text-2xl font-semibold tracking-[-0.03em] text-foreground">
        Extensions
      </h1>
      <p class="m-0 text-sm leading-6 text-muted-foreground">
        Connect focused capabilities to the Content Studio without changing the
        core.
      </p>
    </div>
    <a
      class="inline-flex min-h-9 items-center justify-center gap-2 rounded-md border border-primary bg-primary px-3.5 py-2 text-sm font-semibold leading-5 text-primary-foreground shadow-sm transition-colors hover:bg-primary/90 max-[640px]:w-full"
      href="#install-extension"
      ><svg
        class="h-4 w-4"
        viewBox="0 0 24 24"
        aria-hidden="true"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="M12 5v14M5 12h14" /></svg
      ><span>Install extension</span></a
    >
  </header>

  {% if not message is empty %}
  <div
    class="rounded-lg border border-border bg-card px-4 py-3 text-sm text-foreground shadow-sm"
    role="status"
  >
    {{ message }}
  </div>
  {% endif %} {% if not error is empty %}
  <div
    class="rounded-lg border border-destructive/40 bg-destructive/10 px-4 py-3 text-sm text-destructive"
    role="alert"
  >
    {{ error }}
  </div>
  {% endif %}

  <section
    class="grid grid-cols-4 divide-x divide-border overflow-hidden rounded-xl border border-border bg-card shadow-sm max-[760px]:grid-cols-2 max-[760px]:divide-x-0 max-[760px]:divide-y max-[640px]:rounded-lg"
    aria-label="Extension summary"
  >
    {% for stat in [["Installed", stats["total"]|default(0), "Available packages"], ["Enabled", stats["enabled"]|default(0), "Active at runtime"], ["Configured", stats["configured"]|default(0), "Have settings"], ["Types", stats["types"]|default(0), "Extension categories"]] %}<div class="grid gap-1 px-5 py-4 max-[640px]:px-4">
      <span class="text-xs font-medium text-muted-foreground"
        >{{ stat[0] }}</span
      ><strong class="text-xl font-semibold tracking-[-0.02em] text-foreground"
        >{{ stat[1] }}</strong
      ><span class="text-xs text-muted-foreground">{{ stat[2] }}</span>
    </div>
    {% endfor %}
  </section>

  <section
    id="install-extension"
    class="overflow-hidden rounded-xl border border-border bg-card shadow-sm max-[640px]:rounded-lg"
  >
    <div
      class="flex items-center justify-between gap-4 border-b border-border px-5 py-4 max-[640px]:px-4"
    >
      <div class="grid gap-0.5">
        <h2
          class="m-0 text-base font-semibold tracking-[-0.01em] text-foreground"
        >
          Install a new extension
        </h2>
        <p class="m-0 text-xs text-muted-foreground">
          Upload a ZIP containing an extension manifest and PHP files.
        </p>
      </div>
      <svg
        class="hidden h-5 w-5 text-muted-foreground sm:block"
        viewBox="0 0 24 24"
        aria-hidden="true"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="M12 3v12M7 8l5-5 5 5M5 21h14" />
      </svg>
    </div>
    <form
      method="post"
      enctype="multipart/form-data"
      class="flex items-end gap-3 px-5 py-4 max-[640px]:flex-col max-[640px]:items-stretch max-[640px]:px-4"
    >
      <input type="hidden" name="csrf_token" value="{{ csrf }}" /><input
        type="hidden"
        name="action"
        value="install"
      />
      <div class="grid min-w-0 flex-1 gap-1.5">
        <label
          class="text-xs font-medium text-foreground"
          for="extension-package"
          >Extension package</label
        ><input
          class="min-h-9 w-full cursor-pointer rounded-md border border-input bg-card px-2.5 py-2 text-xs text-foreground file:mr-3 file:cursor-pointer file:border-0 file:bg-transparent file:text-xs file:font-semibold file:text-primary"
          id="extension-package"
          type="file"
          name="extension"
          accept=".zip,application/zip"
          required
        />
      </div>
      <button
        class="inline-flex min-h-9 shrink-0 items-center justify-center gap-2 rounded-md border border-primary bg-primary px-3.5 py-2 text-sm font-semibold leading-5 text-primary-foreground transition-colors hover:bg-primary/90 max-[640px]:w-full"
        type="submit"
      >
        <svg
          class="h-4 w-4"
          viewBox="0 0 24 24"
          aria-hidden="true"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M12 5v14M5 12h14" /></svg
        ><span>Install extension</span>
      </button>
    </form>
  </section>

  <section
    class="overflow-hidden rounded-xl border border-border bg-card text-card-foreground shadow-sm max-[640px]:rounded-lg"
  >
    <header
      class="flex items-center justify-between gap-4 border-b border-border px-5 py-4 max-[640px]:px-4"
    >
      <div class="grid gap-0.5">
        <h2 class="m-0 text-base font-semibold tracking-[-0.01em]">
          Installed extensions
        </h2>
        <p class="m-0 text-xs text-muted-foreground">
          Enable, configure, or remove capabilities from your workspace.
        </p>
      </div>
      <span
        class="hidden rounded-full bg-muted px-2 py-1 text-xs font-medium text-muted-foreground sm:inline-flex"
        >{{ stats['total'] }} installed</span
      >
    </header>
    {% if not extensions['items'] %}
    <div
      class="flex flex-col items-center justify-center gap-2 p-10 text-center text-sm text-muted-foreground"
    >
      <p class="m-0">No extensions are installed.</p>
      <a
        class="text-primary underline-offset-4 hover:underline"
        href="#install-extension"
        >Install the first extension</a
      >
    </div>
    {% else %}
    <div
      class="flex flex-wrap items-center justify-between gap-3 border-b border-border px-5 py-3 max-[640px]:items-stretch max-[640px]:px-4"
    >
      <div role="group" class="flex items-center gap-2">
        <label
          class="text-xs font-medium text-muted-foreground"
          for="extension-type-filter"
          >Filter</label
        ><select
          class="min-h-9 cursor-pointer rounded-md border border-input bg-card px-2.5 py-2 text-xs font-medium text-foreground shadow-sm outline-none focus:border-ring focus:ring-2 focus:ring-ring/20"
          id="extension-type-filter"
          data-extension-grid-type
        >
          <option value="">All types</option>
          {% for type in extensions['types'] %}
          <option value="{{ type['value'] }}">{{ type['label'] }}</option>
          {% endfor %}
        </select>
      </div>
      <label class="relative block w-64 max-w-full"
        ><span class="sr-only">Search extensions</span
        ><svg
          class="pointer-events-none absolute left-2.5 top-1/2 h-4 w-4 -translate-y-1/2 text-muted-foreground"
          viewBox="0 0 24 24"
          aria-hidden="true"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <circle cx="11" cy="11" r="8" />
          <path d="m21 21-4.3-4.3" /></svg
        ><input
          class="min-h-9 w-full rounded-md border border-input bg-card py-2 pl-8 pr-3 text-xs text-foreground shadow-sm outline-none transition-colors placeholder:text-muted-foreground focus:border-ring focus:ring-2 focus:ring-ring/20"
          id="extension-search"
          type="search"
          placeholder="Search extensions..."
          data-extension-grid-filter
      /></label>
    </div>
    <div
      class="grid grid-cols-[repeat(auto-fill,minmax(18rem,1fr))] gap-4 p-5 max-[640px]:grid-cols-1 max-[640px]:p-4"
      data-extension-grid
    >
      {% for extension in extensions['items'] %}
      <article
        class="group grid gap-4 rounded-xl border border-border bg-card p-5 text-card-foreground shadow-sm transition-shadow hover:shadow-md"
        data-extension-type="{{ extension['type'] }}"
      >
        <header class="flex items-start justify-between gap-3">
          <div class="flex min-w-0 items-center gap-3">
            <span
              class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-sm font-semibold text-primary"
              aria-hidden="true"
              >{{ extension['initial'] }}</span
            >
            <div class="grid min-w-0 gap-0.5">
              <h3 class="truncate text-sm font-semibold text-foreground">
                {{ extension['name'] }}
              </h3>
              <p class="m-0 text-xs text-muted-foreground">
                {{ extension['type_label'] }} · v{{ extension['version'] }}
              </p>
            </div>
          </div>
          <span
            class="inline-flex shrink-0 items-center gap-1.5 text-xs font-medium {{ extension['enabled']  and  extension['loaded'] ? 'text-emerald-600 dark:text-emerald-400' : (extension['enabled'] ? 'text-amber-700 dark:text-amber-300' : 'text-muted-foreground') }}"
            ><span
              class="h-1.5 w-1.5 rounded-full {{ extension['enabled']  and  extension['loaded'] ? 'bg-emerald-500' : (extension['enabled'] ? 'bg-amber-500' : 'bg-muted-foreground/50') }}"
            ></span
            >{{ extension['status_label'] }}</span
          >
        </header>
        <p class="m-0 min-h-10 text-sm leading-5 text-muted-foreground">
          {{ extension['description'] }}
        </p>
        <dl class="grid gap-2 border-t border-border pt-3 text-xs">
          <div class="flex items-center justify-between gap-3">
            <dt class="text-muted-foreground">Contexts</dt>
            <dd class="m-0 text-end font-medium text-foreground">
              {{ extension['contexts_label'] ?: 'None' }}
            </dd>
          </div>
          <div class="flex items-center justify-between gap-3">
            <dt class="text-muted-foreground">Services</dt>
            <dd class="m-0 font-medium text-foreground">
              {{ extension['services']|length }} registered
            </dd>
          </div>
        </dl>
        <footer
          class="flex items-center justify-end gap-2 border-t border-border pt-3"
        >
          {% if extension['settings_url'] != '' %}<a
            class="inline-flex h-8 items-center justify-center rounded-md border border-border bg-card px-2.5 text-xs font-semibold text-foreground transition-colors hover:bg-accent hover:text-accent-foreground"
            href="{{ extension['settings_url'] }}"
            >Settings</a
          >{% endif %}
          <form method="post">
            <input type="hidden" name="csrf_token" value="{{ csrf }}" /><input
              type="hidden"
              name="extension"
              value="{{ extension['name'] }}"
            /><input
              type="hidden"
              name="enabled"
              value="{{ extension['enabled'] ? '0' : '1' }}"
            /><button
              type="submit"
              class="inline-flex h-8 items-center justify-center rounded-md border border-border bg-card px-2.5 text-xs font-semibold text-foreground transition-colors hover:bg-accent hover:text-accent-foreground"
            >
              {{ extension['enabled'] ? 'Disable' : 'Enable' }}
            </button>
          </form>
          {% if not extension['removable'] is empty %}
          <form
            method="post"
            data-confirm="Remove this extension package? Its saved settings will remain in the database."
          >
            <input type="hidden" name="csrf_token" value="{{ csrf }}" /><input
              type="hidden"
              name="action"
              value="remove"
            /><input
              type="hidden"
              name="extension"
              value="{{ extension['name'] }}"
            /><button
              type="submit"
              aria-label="Remove {{ extension['name'] }}"
              data-tooltip="Remove extension"
              class="inline-flex h-8 w-8 items-center justify-center rounded-md text-muted-foreground transition-colors hover:bg-destructive/10 hover:text-destructive focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring"
            >
              <svg
                class="h-4 w-4"
                viewBox="0 0 24 24"
                aria-hidden="true"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path
                  d="M3 6h18M8 6V4h8v2M19 6l-1 15H6L5 6M10 11v6M14 11v6"
                /></svg
              ><span class="sr-only">Remove</span>
            </button>
          </form>
          {% endif %}
        </footer>
      </article>
      {% endfor %}
    </div>
    <div
      class="flex flex-col items-center justify-center gap-2 p-8 text-center text-sm text-muted-foreground"
      data-extension-grid-empty
      hidden
    >
      <p class="m-0">No extensions match this filter.</p>
    </div>
    {% endif %}
  </section>
</main>
{{ footer | raw }}
