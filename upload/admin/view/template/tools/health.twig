{{ header | raw }}
<main
  class="mx-auto grid w-[min(calc(100%-3rem),82rem)] gap-6 py-7 pb-10 text-sm max-[900px]:w-[min(calc(100%-2rem),82rem)] max-[640px]:gap-5 max-[640px]:py-5"
>
  <nav
    class="flex items-center gap-2 text-xs text-muted-foreground"
    aria-label="Breadcrumb"
  >
    <a class="transition-colors hover:text-foreground" href="/admin"
      >Workspace</a
    ><svg
      class="h-3.5 w-3.5"
      viewBox="0 0 24 24"
      aria-hidden="true"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <path d="m9 18 6-6-6-6" /></svg
    ><span class="font-medium text-foreground">Content health</span>
  </nav>
  <header
    class="flex items-end justify-between gap-4 max-[640px]:items-stretch max-[640px]:flex-col"
  >
    <div>
      <p
        class="m-0 text-xs font-semibold uppercase tracking-[0.08em] text-muted-foreground"
      >
        Content Studio
      </p>
      <h1
        class="m-[0.2rem_0_0.3rem] text-2xl font-semibold tracking-[-0.025em]"
      >
        Content health
      </h1>
      <p class="max-w-2xl text-sm leading-6 text-muted-foreground">
        Fast checks for publishing quality, missing assets, internal links, and
        sensitive values.
      </p>
    </div>
    <a
      class="inline-flex min-h-9 items-center justify-center rounded-md border border-border bg-card px-3.5 py-2 text-sm font-semibold text-foreground shadow-sm hover:bg-accent hover:text-accent-foreground"
      href="/admin/editor"
      >Open editor</a
    >
  </header>
  <section
    class="grid grid-cols-4 overflow-hidden rounded-xl border border-border bg-card shadow-sm max-[760px]:grid-cols-2 max-[480px]:grid-cols-1"
    aria-label="Content health summary"
  >
    <div class="px-5 py-4">
      <p class="text-xs text-muted-foreground">Total pages</p>
      <strong class="mt-1 block text-xl font-semibold"
        >{{ health['pages'] }}</strong
      >
    </div>
    <div
      class="border-l border-border px-5 py-4 max-[760px]:border-t max-[480px]:border-l-0"
    >
      <p class="text-xs text-muted-foreground">Private pages</p>
      <strong class="mt-1 block text-xl font-semibold"
        >{{ health['private'] }}</strong
      >
    </div>
    <div
      class="border-l border-border px-5 py-4 max-[760px]:border-t max-[480px]:border-l-0"
    >
      <p class="text-xs text-muted-foreground">Drafts</p>
      <strong class="mt-1 block text-xl font-semibold"
        >{{ health['drafts'] }}</strong
      >
    </div>
    <div
      class="border-l border-border px-5 py-4 max-[760px]:border-t max-[480px]:border-l-0"
    >
      <p class="text-xs text-muted-foreground">Items to review</p>
      <strong
        class="mt-1 block text-xl font-semibold {{ severity_counts['error'] ? 'text-destructive' : '' }}"
        >{{ health['issue_count'] }}</strong
      >
    </div>
  </section>
  <section
    class="overflow-hidden rounded-xl border border-border bg-card shadow-sm"
  >
    <header
      class="flex items-start justify-between gap-4 border-b border-border px-5 py-4 max-[640px]:flex-col max-[640px]:px-4"
    >
      <div>
        <p
          class="m-0 text-xs font-semibold uppercase tracking-wide text-muted-foreground"
        >
          Review queue
        </p>
        <h2 class="mt-1 text-base font-semibold">Content health findings</h2>
        <p class="mt-1 text-xs text-muted-foreground">
          Review issues by severity and jump directly to the source when
          possible.
        </p>
      </div>
      <span
        class="rounded-full {{ severity_counts['error'] ? 'bg-destructive/10 text-destructive' : 'bg-muted text-muted-foreground' }} px-2.5 py-1 text-xs font-medium"
        >{{ health['issues'] ? health['issue_count'] ~ ' found' : 'All clear'
        }}</span
      >
    </header>
    {% if not health['issues'] %}
    <div
      class="m-5 flex flex-col items-center justify-center gap-2 rounded-lg border border-dashed border-border px-6 py-12 text-center text-sm text-muted-foreground"
    >
      <svg
        class="size-7 text-emerald-600"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="1.8"
          d="m5 12 4 4L19 6"
        />
      </svg>
      <p class="m-0 font-medium text-foreground">Everything looks healthy</p>
      <p class="m-0">
        No broken links, missing uploads, or metadata warnings were found.
      </p>
    </div>
    {% else %}
    <div class="overflow-x-auto">
      <table class="w-full min-w-[54rem] border-collapse text-sm">
        <thead class="bg-muted/40">
          <tr>
            <th
              class="px-5 py-2.5 text-start text-[11px] font-semibold uppercase tracking-wide text-muted-foreground"
            >
              Finding
            </th>
            <th
              class="px-3 py-2.5 text-start text-[11px] font-semibold uppercase tracking-wide text-muted-foreground"
            >
              File
            </th>
            <th
              class="px-3 py-2.5 text-start text-[11px] font-semibold uppercase tracking-wide text-muted-foreground"
            >
              Line
            </th>
            <th
              class="px-5 py-2.5 text-end text-[11px] font-semibold uppercase tracking-wide text-muted-foreground"
            >
              Severity
            </th>
          </tr>
        </thead>
        <tbody>
          {% for issue in health['issues'] %}
          <tr
            class="border-t border-border transition-colors hover:bg-muted/30"
          >
            <td class="max-w-[34rem] px-5 py-3 text-sm">
              {% if issue['url'] != '' %}<a
                class="font-medium text-primary hover:underline"
                href="{{ issue['url'] }}"
                >{{ issue['message'] }}</a
              >{% else %}<span>{{ issue['message'] }}</span>{% endif %}
            </td>
            <td class="px-3 py-3">
              <code
                class="rounded bg-muted px-1.5 py-1 text-xs text-muted-foreground"
                >{{ issue['file'] }}</code
              >
            </td>
            <td class="px-3 py-3 text-xs text-muted-foreground">
              {{ issue['line'] }}
            </td>
            <td class="px-5 py-3 text-end">
              <span
                class="inline-flex items-center rounded-full px-2.5 py-1 text-xs font-medium {{ issue['severity_class'] }}"
                >{{ issue['severity']|capitalize }}</span
              >
            </td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
    {% endif %}
  </section>
  <aside
    class="flex gap-3 rounded-lg border border-border bg-muted/30 px-4 py-3 text-xs leading-5 text-muted-foreground"
  >
    <svg
      class="mt-0.5 size-4 shrink-0 text-primary"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
    >
      <circle cx="12" cy="12" r="9" stroke-width="1.8" />
      <path stroke-linecap="round" stroke-width="1.8" d="M12 10v6m0-9h.01" />
    </svg>
    <p class="m-0">
      <strong class="font-semibold text-foreground"
        >How to use this queue:</strong
      >
      Linked Markdown findings open in the editor. Missing uploaded assets open
      the media library; other findings remain informational until their source
      is corrected.
    </p>
  </aside>
</main>
{{ footer | raw }}
