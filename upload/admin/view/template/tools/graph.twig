{{ header | raw }}
<main
  class="mx-auto grid w-[min(calc(100%-3rem),82rem)] gap-6 py-7 pb-10 text-sm max-[900px]:w-[min(calc(100%-2rem),82rem)] max-[640px]:gap-5 max-[640px]:py-5"
>
  <nav
    class="flex items-center gap-2 text-xs text-muted-foreground"
    aria-label="Breadcrumb"
  >
    <a class="transition-colors hover:text-foreground" href="/admin"
      >Workspace</a
    ><svg
      class="h-3.5 w-3.5"
      viewBox="0 0 24 24"
      aria-hidden="true"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <path d="m9 18 6-6-6-6" /></svg
    ><span class="font-medium text-foreground">Content map</span>
  </nav>
  <header
    class="flex items-end justify-between gap-4 max-[640px]:items-stretch max-[640px]:flex-col"
  >
    <div>
      <p
        class="m-0 text-xs font-semibold uppercase tracking-[0.08em] text-muted-foreground"
      >
        Content intelligence
      </p>
      <h1
        class="m-[0.2rem_0_0.3rem] text-2xl font-semibold tracking-[-0.025em]"
      >
        Documentation relationships
      </h1>
      <p class="max-w-2xl text-sm leading-6 text-muted-foreground">
        Explore incoming and outgoing links to understand how your documentation
        is connected and where isolated pages need attention.
      </p>
    </div>
    <a
      class="inline-flex min-h-9 items-center justify-center gap-2 rounded-md border border-border bg-card px-3.5 py-2 text-sm font-semibold text-foreground shadow-sm hover:bg-accent hover:text-accent-foreground"
      href="/admin/editor"
      >Open editor</a
    >
  </header>
  <section
    class="grid grid-cols-4 overflow-hidden rounded-xl border border-border bg-card shadow-sm max-[760px]:grid-cols-2 max-[480px]:grid-cols-1"
  >
    <div class="px-5 py-4">
      <p class="text-xs text-muted-foreground">Published pages</p>
      <strong class="mt-1 block text-xl font-semibold"
        >{{ stats['pages'] }}</strong
      >
    </div>
    <div
      class="border-l border-border px-5 py-4 max-[760px]:border-t max-[480px]:border-l-0"
    >
      <p class="text-xs text-muted-foreground">Outgoing links</p>
      <strong class="mt-1 block text-xl font-semibold"
        >{{ stats['links'] }}</strong
      >
    </div>
    <div
      class="border-l border-border px-5 py-4 max-[760px]:border-t max-[480px]:border-l-0"
    >
      <p class="text-xs text-muted-foreground">Connected pages</p>
      <strong class="mt-1 block text-xl font-semibold"
        >{{ stats['connected'] }}</strong
      >
    </div>
    <div
      class="border-l border-border px-5 py-4 max-[760px]:border-t max-[480px]:border-l-0"
    >
      <p class="text-xs text-muted-foreground">Isolated pages</p>
      <strong
        class="mt-1 block text-xl font-semibold {{ stats['orphans'] ? 'text-amber-700 dark:text-amber-300' : '' }}"
        >{{ stats['orphans'] }}</strong
      >
    </div>
  </section>
  <section
    class="overflow-hidden rounded-xl border border-border bg-card shadow-sm"
  >
    <header
      class="flex items-end justify-between gap-4 border-b border-border px-5 py-4 max-[640px]:flex-col max-[640px]:items-stretch max-[640px]:px-4"
    >
      <div>
        <p
          class="m-0 text-xs font-semibold uppercase tracking-wide text-muted-foreground"
        >
          Relationship map
        </p>
        <h2 class="mt-1 text-base font-semibold">Page connections</h2>
        <p class="mt-1 text-xs text-muted-foreground">
          Select a page to open it in the editor.
        </p>
      </div>
      <label class="relative block w-64 max-w-full"
        ><span class="sr-only">Filter pages</span
        ><svg
          class="pointer-events-none absolute left-2.5 top-2.5 size-4 text-muted-foreground"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <circle cx="11" cy="11" r="7" stroke-width="1.8" />
          <path stroke-linecap="round" stroke-width="1.8" d="m20 20-4-4" /></svg
        ><input
          class="min-h-9 w-full rounded-md border border-input bg-card py-2 pl-8 pr-2.5 text-xs text-foreground shadow-sm outline-none placeholder:text-muted-foreground focus:border-ring focus:ring-2 focus:ring-ring/20"
          type="search"
          placeholder="Filter pages"
          data-graph-filter
      /></label>
    </header>
    {% if not relationships %}
    <div
      class="m-5 rounded-lg border border-dashed border-border px-6 py-12 text-center text-sm text-muted-foreground"
    >
      No published pages are available to map.
    </div>
    {% else %}
    <div
      class="grid grid-cols-[repeat(auto-fill,minmax(20rem,1fr))] gap-4 p-5 max-[640px]:p-4"
      data-graph-list
    >
      {% for item in relationships %}
      <article
        class="grid gap-4 rounded-lg border {{ item['orphan'] ? 'border-amber-300 dark:border-amber-800' : 'border-border' }} bg-card p-4 transition-shadow hover:shadow-sm"
        data-graph-item
        data-search="{{ item['search_text'] }}"
      >
        <header class="flex items-start justify-between gap-3">
          <div class="min-w-0">
            <span
              class="block truncate text-xs text-muted-foreground"
              title="{{ item['path'] }}"
              >{{ item['path'] }}</span
            ><strong
              class="mt-0.5 block truncate text-sm font-semibold text-foreground"
              title="{{ item['title'] }}"
              >{{ item['title'] }}</strong
            >
          </div>
          <a
            class="inline-flex min-h-8 shrink-0 items-center justify-center rounded-md border border-border bg-card px-2.5 py-1.5 text-xs font-semibold text-foreground hover:bg-accent hover:text-accent-foreground"
            href="{{ item['page_url'] }}"
            >Edit</a
          >
        </header>
        <div class="grid grid-cols-2 gap-3 max-[640px]:grid-cols-1">
          <section
            class="grid content-start gap-1.5"
            aria-label="Incoming links"
          >
            <span
              class="flex items-center justify-between text-[11px] font-semibold uppercase tracking-wide text-muted-foreground"
              ><span>Incoming</span
              ><span class="rounded-full bg-muted px-1.5 py-0.5 text-[10px]"
                >{{ item['incoming']|length }}</span
              ></span
            >{% for page in item['incoming'] %}<a
              class="truncate rounded-md border border-border bg-muted/20 px-2 py-1.5 text-xs text-foreground hover:bg-accent hover:text-accent-foreground"
              href="{{ page['url'] }}"
              title="{{ page['title'] }}"
              >{{ page['title'] }}</a
            >{% endfor %}{% if not item['incoming'] %}<span
              class="text-xs text-muted-foreground"
              >No incoming links</span
            >{% endif %}
          </section>
          <section
            class="grid content-start gap-1.5"
            aria-label="Outgoing links"
          >
            <span
              class="flex items-center justify-between text-[11px] font-semibold uppercase tracking-wide text-muted-foreground"
              ><span>Outgoing</span
              ><span class="rounded-full bg-muted px-1.5 py-0.5 text-[10px]"
                >{{ item['outgoing']|length }}</span
              ></span
            >{% for page in item['outgoing'] %}<a
              class="truncate rounded-md border border-border bg-muted/20 px-2 py-1.5 text-xs text-foreground hover:bg-accent hover:text-accent-foreground"
              href="{{ page['url'] }}"
              title="{{ page['title'] }}"
              >{{ page['title'] }}</a
            >{% endfor %}{% if not item['outgoing'] %}<span
              class="text-xs text-muted-foreground"
              >No outgoing links</span
            >{% endif %}
          </section>
        </div>
        {% if item['orphan'] %}
        <div
          class="rounded-md bg-amber-50 px-2.5 py-2 text-xs text-amber-900 dark:bg-amber-950/40 dark:text-amber-200"
        >
          No incoming links — this page may be isolated.
        </div>
        {% endif %}
      </article>
      {% endfor %}
    </div>
    <div
      class="hidden px-6 py-12 text-center text-sm text-muted-foreground"
      data-graph-empty
    >
      No pages match this filter.
    </div>
    {% endif %}
  </section>
  <aside
    class="flex gap-3 rounded-lg border border-border bg-muted/30 px-4 py-3 text-xs leading-5 text-muted-foreground"
  >
    <svg
      class="mt-0.5 size-4 shrink-0 text-primary"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
    >
      <circle cx="12" cy="12" r="9" stroke-width="1.8" />
      <path stroke-linecap="round" stroke-width="1.8" d="M12 10v6m0-9h.01" />
    </svg>
    <p class="m-0">
      <strong class="font-semibold text-foreground"
        >How to read the map:</strong
      >
      Incoming links show pages that reference this page; outgoing links show
      the pages it references. The home page is excluded from isolated-page
      warnings.
    </p>
  </aside>
</main>
<script nonce="{{ csp_nonce ?? '' }}">
  (() => {
    const input = document.querySelector("[data-graph-filter]");
    const items = [...document.querySelectorAll("[data-graph-item]")];
    const empty = document.querySelector("[data-graph-empty]");
    input?.addEventListener("input", () => {
      const query = input.value.trim().toLowerCase();
      let visible = 0;
      items.forEach((item) => {
        const match = !query || item.dataset.search.includes(query);
        item.classList.toggle("hidden", !match);
        if (match) visible++;
      });
      empty?.classList.toggle("hidden", visible !== 0);
    });
  })();
</script>
{{ footer | raw }}
