{% set markdown_url = page.url == '/' ? '/index.md' : page.url ~ '.md' %} {% set
service = page.service() %} {% set reviewed = page.reviewedAt() %}
<article
  class="min-w-0 print:[&_a]:text-black"
  data-docs-article
  data-page-type="{{ page.type() }}"
>
  <header class="mb-7 border-b border-[var(--border)] pb-6 pt-1">
    {% if page.type() == 'runbook' or page.isPrivate() %}
    <div
      class="mb-3 flex items-center gap-2 text-xs font-semibold uppercase tracking-[.06em] text-[var(--brand-strong)]"
    >
      {% if page.type() == 'runbook' %}<span>Operational runbook</span
      ><span
        class="inline-flex rounded-full border border-[color-mix(in_srgb,#3b82f6_24%,var(--border))] bg-[var(--info-soft)] px-1.5 py-[3px] text-xs normal-case tracking-normal text-[var(--info)]"
        >Checklist</span
      >{% endif %}{% if page.isPrivate() %}<span
        class="inline-flex items-center rounded-full border border-[color-mix(in_srgb,#f59e0b_24%,var(--border))] bg-[var(--warn-soft)] px-[7px] py-1 text-[11px] font-[650] normal-case tracking-normal text-[var(--warn)]"
        >Private</span
      >{% endif %}
    </div>
    {% endif %}
    <h1
      class="m-0 max-w-[760px] text-[clamp(1.75rem,3vw,2rem)] font-bold leading-[1.2] tracking-[-.035em] text-[var(--text-strong)] text-balance"
    >
      {{ page.title }}
    </h1>
    {% if page.description %}
    <p class="mt-3 max-w-[660px] text-base leading-7 text-[var(--muted)]">
      {{ page.description }}
    </p>
    {% endif %}
    <div class="mt-[18px] flex items-center gap-1.5">
      <button
        class="inline-flex min-h-8 items-center gap-1.5 rounded-[var(--radius-sm)] border border-[var(--border)] bg-[var(--surface)] px-2.5 py-1.5 text-[13px] text-[var(--muted)] hover:border-[var(--border-strong)] hover:bg-[var(--surface-subtle)] hover:text-[var(--text)]"
        type="button"
        data-copy-markdown
        data-markdown-url="{{ markdown_url }}"
      >
        <span class="text-sm leading-none" aria-hidden="true">⧉</span>Copy
        Markdown
      </button>
      <details class="group relative" data-page-actions>
        <summary
          class="grid min-h-8 w-8 cursor-pointer list-none place-items-center rounded-[var(--radius-sm)] border border-[var(--border)] bg-[var(--surface)] text-[15px] tracking-[.08em] text-[var(--muted)] hover:border-[var(--border-strong)] hover:bg-[var(--surface-subtle)] hover:text-[var(--text)] [&::-webkit-details-marker]:hidden"
          aria-label="More page actions"
        >
          •••
        </summary>
        <div
          class="absolute [inset-inline-start:0] top-[calc(100%+6px)] z-30 grid w-52 gap-0.5 rounded-[var(--radius-md)] border border-[var(--border)] bg-[var(--surface-raised)] p-1.5 text-[13px] text-[var(--muted)] shadow-[var(--shadow-lg)]"
        >
          <a
            class="rounded-[5px] px-2.5 py-2 hover:bg-[var(--surface-hover)] hover:text-[var(--text)]"
            href="{{ markdown_url }}"
            >Open raw Markdown <span class="float-end">↗</span></a
          ><button
            class="rounded-[5px] px-2.5 py-2 text-start hover:bg-[var(--surface-hover)] hover:text-[var(--text)]"
            type="button"
            data-copy-link
          >
            Copy page link</button
          ><button
            class="rounded-[5px] px-2.5 py-2 text-start hover:bg-[var(--surface-hover)] hover:text-[var(--text)]"
            type="button"
            data-copy-ai-prompt
            data-markdown-url="{{ markdown_url }}"
            data-page-title="{{ page.title }}"
          >
            Copy AI prompt</button
          >{% if not config['editor_enabled'] is empty %}<a
            class="rounded-[5px] px-2.5 py-2 hover:bg-[var(--surface-hover)] hover:text-[var(--text)]"
            href="/admin/editor?file={{ page.relative_path|url_encode|replace({'%2F': '/'}) }}"
            >Edit in Studio <span class="float-end">↗</span></a
          >{% endif %}
        </div>
      </details>
    </div>
    {% if service or page.verifiedWith() %}
    <div class="mt-[18px] flex flex-wrap gap-1.5">
      {% if service.context is defined %}<span
        class="rounded-md border border-[var(--border)] bg-[var(--surface-subtle)] px-1.5 py-1 font-mono text-[11px] text-[var(--muted)]"
        >{{ service.context }}</span
      >{% endif %}{% if service.id is defined %}<span
        class="rounded-md border border-[var(--border)] bg-[var(--surface-subtle)] px-1.5 py-1 font-mono text-[11px] text-[var(--muted)]"
        >CT {{ service.id }}</span
      >{% endif %}{% if service.address is defined %}<span
        class="rounded-md border border-[var(--border)] bg-[var(--surface-subtle)] px-1.5 py-1 font-mono text-[11px] text-[var(--muted)]"
        >{{ service.address }}</span
      >{% endif %}{% for product, version in page.verifiedWith() %}<span
        class="rounded-md border border-[var(--border)] bg-[var(--surface-subtle)] px-1.5 py-1 font-mono text-[11px] text-[var(--muted)]"
        >Verified: {{ product|replace({'_': ' '})|title }} {{ version }}</span
      >{% endfor %}
    </div>
    {% endif %}
    <div
      class="mt-3.5 flex items-center gap-[9px] text-[13px] text-[var(--faint)]"
    >
      <span>Updated {{ page.modified_at|date('M j, Y') }}</span>{% if reviewed
      %}<span
        class="inline-block h-[3px] w-[3px] rounded-full bg-[var(--border-strong)]"
      ></span
      ><span
        class="{{ page.isReviewStale() ? 'text-[var(--warn)]' : 'text-[var(--ok)]' }}"
        >{{ page.isReviewStale() ? 'Review overdue' : 'Reviewed ' ~
        (reviewed|date('M j, Y')) }}</span
      >{% endif %}{% if page.isPrivate() %}<span
        class="inline-block h-[3px] w-[3px] rounded-full bg-[var(--border-strong)]"
      ></span
      ><span>Authenticated view</span>{% endif %}
    </div>
    {% if page.type() == 'runbook' and task_count > 0 %}
    <div
      class="mt-5 grid grid-cols-[1fr_auto] gap-x-3.5 gap-y-2 rounded-[var(--radius-md)] border border-[var(--border)] bg-[var(--surface-subtle)] p-[13px_14px] max-[700px]:grid-cols-1"
      data-runbook-progress
    >
      <div class="flex justify-between gap-5 text-[11px] text-[var(--muted)]">
        <span>Runbook progress</span
        ><strong class="font-semibold text-[var(--text)]" data-progress-label
          >0 of {{ task_count }} complete</strong
        >
      </div>
      <div
        class="col-start-1 h-1 overflow-hidden rounded-full bg-[var(--border)]"
      >
        <span
          class="block h-full w-0 rounded-full bg-[var(--brand)] transition-[width] duration-200"
          data-progress-bar
        ></span>
      </div>
      <div
        class="col-start-2 row-span-2 row-start-1 flex items-stretch gap-1.5 max-[700px]:col-start-1 max-[700px]:row-auto"
      >
        <a
          class="inline-flex items-center justify-center rounded-md border border-[var(--border)] bg-[var(--surface)] px-2 text-xs text-[var(--muted)] hover:border-[var(--brand)] hover:text-[var(--brand-strong)]"
          href="#runbook-checklist"
          >Open checklist</a
        ><button
          class="inline-flex items-center justify-center rounded-md border border-[var(--border)] bg-[var(--surface)] px-2 text-xs text-[var(--muted)] hover:border-[var(--brand)] hover:text-[var(--brand-strong)]"
          type="button"
          data-reset-runbook
        >
          Reset
        </button>
      </div>
    </div>
    {% endif %}
  </header>
  <div
    class="text-base leading-[1.78] text-[var(--text)] max-[540px]:text-[15px] print:text-[11pt] [[data-reading-text-size=small]_&]:text-[14.5px] [[data-reading-text-size=small]_&]:leading-[1.7] [[data-reading-text-size=large]_&]:text-lg [[data-reading-text-size=large]_&]:leading-[1.78] [[data-density=compact]_&]:text-[15px] [[data-density=compact]_&]:leading-[1.68] [&_h1]:mb-[.7em] [&_h1]:mt-[1.8em] [&_h1]:text-[1.75rem] [&_h1:first-child]:mt-0 [&_h2]:mb-[.65em] [&_h2]:mt-[2em] [&_h2]:pt-[.2em] [&_h2]:text-[1.45rem] [&_h2:first-child]:mt-0 [&_h3]:mb-[.55em] [&_h3]:mt-[1.75em] [&_h3]:text-[1.2rem] [&_h3:first-child]:mt-0 [&_h4]:mb-[.45em] [&_h4]:mt-[1.5em] [&_h4]:text-base [&_h4:first-child]:mt-0 [&_p]:mb-[1em] [&_ol]:mb-[1em] [&_ol]:pl-[1.45em] [&_ul]:mb-[1em] [&_ul]:pl-[1.45em] [&_li+li]:mt-[.32em] [&_li::marker]:text-[var(--faint)] [&_strong]:font-[680] [&_strong]:text-[var(--text-strong)] [&_a]:font-[520] [&_a]:text-[var(--brand-strong)] [&_a]:underline [&_a]:decoration-[color-mix(in_srgb,var(--brand)_35%,transparent)] [&_a]:underline-offset-[3px] [&_a:hover]:decoration-[var(--brand)] [&_blockquote]:my-[1.6em] [&_blockquote]:border-l-2 [&_blockquote]:border-[var(--border-strong)] [&_blockquote]:py-0.5 [&_blockquote]:pl-[18px] [&_blockquote]:text-[var(--muted)] [&_hr]:my-[2.8em] [&_hr]:border-0 [&_hr]:border-t [&_hr]:border-[var(--border)] [&_img]:h-auto [&_img]:max-w-full [&_img]:rounded-[calc(var(--radius)+2px)] [&_img]:border [&_img]:border-[var(--border)] [&_img]:shadow-[var(--shadow-sm)] [&_table]:my-[1.7em] [&_table]:w-full [&_table]:max-w-full [&_table]:border-separate [&_table]:border-spacing-0 [&_table]:rounded-[var(--radius-md)] [&_table]:border [&_table]:border-[var(--border)] [&_th]:border-b [&_th]:border-r [&_th]:border-[var(--border)] [&_th]:bg-[var(--surface-subtle)] [&_th]:px-[13px] [&_th]:py-2.5 [&_th]:text-left [&_th]:text-[13px] [&_th]:font-[680] [&_th]:whitespace-normal [&_th]:text-[var(--text-strong)] [&_td]:border-b [&_td]:border-r [&_td]:border-[var(--border)] [&_td]:px-[13px] [&_td]:py-2.5 [&_td]:text-left [&_td]:whitespace-normal [&_tr:last-child_td]:border-b-0 [&_th:last-child]:border-r-0 [&_td:last-child]:border-r-0 [&_:not(pre)>code]:rounded-[5px] [&_:not(pre)>code]:border [&_:not(pre)>code]:border-[var(--border)] [&_:not(pre)>code]:bg-[var(--surface-subtle)] [&_:not(pre)>code]:px-[.4em] [&_:not(pre)>code]:py-[.16em] [&_:not(pre)>code]:font-mono [&_:not(pre)>code]:text-[84%] [&_:not(pre)>code]:text-[color-mix(in_srgb,var(--text)_90%,var(--brand))] [&_input[type=checkbox]]:ml-[-20px] [&_input[type=checkbox]]:mr-[7px] [&_input[type=checkbox]]:h-3.5 [&_input[type=checkbox]]:w-3.5 [&_input[type=checkbox]]:accent-[var(--brand)]"
    data-markdown-body
  >
    {{ rendered.html | raw }}
  </div>
  {% if related or backlinks %}
  <section class="mt-[60px]">
    <h2
      class="mb-3.5 text-base font-semibold tracking-[-.02em] text-[var(--text-strong)]"
    >
      Connected documentation
    </h2>
    <div class="grid grid-cols-2 gap-2 max-[700px]:grid-cols-1">
      {% for connection in related %}<a
        class="relative flex flex-col gap-0.5 rounded-[var(--radius-md)] border border-[var(--border)] bg-[var(--surface)] px-3.5 py-[13px] pr-[34px] hover:border-[color-mix(in_srgb,var(--brand)_35%,var(--border))]"
        href="{{ connection.url }}"
        ><span class="text-xs uppercase tracking-[.05em] text-[var(--faint)]"
          >Related</span
        ><strong class="text-xs">{{ connection.title }}</strong
        ><i
          class="absolute right-[13px] top-1/2 [transform:translateY(-50%)] not-italic text-[var(--faint)]"
          >→</i
        ></a
      >{% endfor %}{% for connection in backlinks %}<a
        class="relative flex flex-col gap-0.5 rounded-[var(--radius-md)] border border-[var(--border)] bg-[var(--surface)] px-3.5 py-[13px] pr-[34px] hover:border-[color-mix(in_srgb,var(--brand)_35%,var(--border))]"
        href="{{ connection.url }}"
        ><span class="text-xs uppercase tracking-[.05em] text-[var(--faint)]"
          >Links here</span
        ><strong class="text-xs">{{ connection.title }}</strong
        ><i
          class="absolute right-[13px] top-1/2 [transform:translateY(-50%)] not-italic text-[var(--faint)]"
          >↗</i
        ></a
      >{% endfor %}
    </div>
  </section>
  {% endif %}
  <footer
    class="mt-[72px] border-t border-[var(--border)] pt-[22px] print:hidden"
    data-page-footer
  >
    <div
      class="flex items-center justify-between gap-5 text-[13px] text-[var(--faint)] max-[540px]:flex-wrap"
    >
      <div class="flex gap-3.5">
        <a class="hover:text-[var(--brand-strong)]" href="{{ markdown_url }}"
          >View source</a
        >{% if not config['editor_enabled'] is empty %}<a
          class="hover:text-[var(--brand-strong)]"
          href="/admin/editor?file={{ page.relative_path|url_encode|replace({'%2F': '/'}) }}"
          >Edit page</a
        >{% endif %}
      </div>
      <div
        class="grid min-w-[252px] grid-cols-3 items-center justify-end gap-1.5"
        data-feedback-section
        data-feedback-page="{{ page.url }}"
      >
        <span class="col-span-full whitespace-nowrap">How is this guide?</span
        ><button
          class="rounded-[5px] border border-[var(--border)] bg-[var(--surface)] px-1.5 py-0.5 hover:border-[var(--brand)] hover:text-[var(--brand-strong)] aria-pressed:border-[color-mix(in_srgb,var(--brand)_45%,var(--border))] aria-pressed:bg-[var(--brand-soft)] aria-pressed:text-[var(--brand-strong)]"
          type="button"
          data-feedback="good"
          aria-pressed="false"
          aria-label="This guide was helpful"
        >
          Good</button
        ><button
          class="rounded-[5px] border border-[var(--border)] bg-[var(--surface)] px-1.5 py-0.5 hover:border-[var(--brand)] hover:text-[var(--brand-strong)] aria-pressed:border-[color-mix(in_srgb,var(--brand)_45%,var(--border))] aria-pressed:bg-[var(--brand-soft)] aria-pressed:text-[var(--brand-strong)]"
          type="button"
          data-feedback="bad"
          aria-pressed="false"
          aria-label="This guide needs improvement"
        >
          Bad</button
        ><small
          class="col-span-full mt-px whitespace-nowrap text-right text-[10.5px] leading-[1.35] text-[var(--muted)]"
          data-feedback-summary
          >{% if feedback['total'] > 0 %}{{ feedback['helpful_percent'] }}%
          helpful from {{ feedback['total'] }} response{{ feedback['total'] == 1
          ? '' : 's' }}{% else %}Be the first to respond{% endif %}</small
        >
      </div>
    </div>
    <nav
      class="mt-[27px] grid grid-cols-2 gap-3 max-[540px]:grid-cols-1"
      aria-label="Adjacent pages"
    >
      {% if previous %}<a
        class="relative flex min-h-[88px] flex-col justify-center rounded-[var(--radius)] border border-[var(--border)] bg-[var(--surface)] py-3.5 pl-[38px] pr-4 transition hover:[transform:translateY(-1px)] hover:border-[color-mix(in_srgb,var(--brand)_35%,var(--border))]"
        href="{{ previous.url }}"
        ><span class="mb-0.5 text-xs text-[var(--faint)]">Previous</span
        ><strong class="text-sm font-semibold text-[var(--text-strong)]"
          >{{ previous.title }}</strong
        ><i
          class="absolute left-[15px] text-[17px] not-italic text-[var(--faint)]"
          aria-hidden="true"
          >←</i
        ></a
      >{% else %}<span></span>{% endif %}{% if next %}<a
        class="relative flex min-h-[88px] flex-col justify-center rounded-[var(--radius)] border border-[var(--border)] bg-[var(--surface)] py-3.5 pl-4 pr-[38px] text-right transition hover:[transform:translateY(-1px)] hover:border-[color-mix(in_srgb,var(--brand)_35%,var(--border))] max-[540px]:text-left"
        href="{{ next.url }}"
        ><span class="mb-0.5 text-xs text-[var(--faint)]">Next</span
        ><strong class="text-sm font-semibold text-[var(--text-strong)]"
          >{{ next.title }}</strong
        ><i
          class="absolute right-[15px] text-[17px] not-italic text-[var(--faint)]"
          aria-hidden="true"
          >→</i
        ></a
      >{% endif %}
    </nav>
  </footer>
</article>
