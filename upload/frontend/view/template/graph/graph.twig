<article class="min-w-0" data-docs-graph-page>
  <header class="mb-7 border-b border-[var(--border)] pb-6 pt-1">
    <p
      class="mb-2 text-xs font-semibold uppercase tracking-[.07em] text-[var(--brand-strong)]"
    >
      Explore
    </p>
    <h1
      class="m-0 text-[clamp(1.75rem,3vw,2rem)] font-bold leading-[1.2] tracking-[-.035em] text-[var(--text-strong)]"
    >
      Documentation graph
    </h1>
    <p class="mt-3 max-w-[660px] text-base leading-7 text-[var(--muted)]">
      See which pages connect, find heavily referenced guides, and discover
      isolated documentation.
    </p>
  </header>
  <div
    class="mb-4 grid grid-cols-[1fr_auto] items-center gap-3 max-[540px]:grid-cols-1"
  >
    <label class="relative block min-w-0"
      ><span class="sr-only">Filter graph pages</span
      ><input
        class="min-h-10 w-full rounded-[var(--radius-md)] border border-[var(--border)] bg-[var(--surface)] px-3 py-2 ps-9 text-sm outline-2 outline-transparent placeholder:text-[var(--faint)] focus:border-[var(--brand)] focus:outline-[color-mix(in_srgb,var(--brand)_22%,transparent)]"
        type="search"
        placeholder="Filter pages…"
        data-graph-filter /><span
        class="pointer-events-none absolute [inset-inline-start:12px] top-1/2 h-3 w-3 -translate-y-1/2 rounded-full border-[1.5px] border-[var(--faint)] after:absolute after:-bottom-1 after:[inset-inline-end:-4px] after:h-px after:w-1 after:rotate-45 after:bg-[var(--faint)]"
        aria-hidden="true"
      ></span
    ></label>
    <p class="text-xs text-[var(--faint)]">
      <strong class="text-[var(--text)]">{{ nodes|length }}</strong> pages ·
      <strong class="text-[var(--text)]">{{ links|length }}</strong> links
    </p>
  </div>
  <div
    class="relative h-[min(62vh,620px)] min-h-[420px] overflow-hidden rounded-[var(--radius-lg)] border border-[var(--border)] bg-[radial-gradient(circle_at_center,color-mix(in_srgb,var(--brand)_7%,var(--surface)),var(--bg)_72%)] max-[540px]:min-h-[360px]"
    data-docs-graph
    data-graph-nodes="{{ nodes|json_encode|e }}"
    data-graph-links="{{ links|json_encode|e }}"
  >
    <svg
      class="h-full w-full"
      role="img"
      aria-label="Interactive map of documentation links"
      data-graph-canvas
    ></svg>
    <p
      class="pointer-events-none absolute inset-x-0 bottom-3 text-center text-[11px] text-[var(--faint)]"
    >
      Select a node to open its page
    </p>
  </div>
  <section class="mt-7" aria-labelledby="graph-pages-title">
    <h2
      class="mb-3 text-lg font-semibold text-[var(--text-strong)]"
      id="graph-pages-title"
    >
      Pages by references
    </h2>
    <div class="grid grid-cols-2 gap-2 max-[700px]:grid-cols-1" data-graph-list>
      {% for node in nodes %}<a
        class="flex items-center justify-between gap-3 rounded-[var(--radius-md)] border border-[var(--border)] bg-[var(--surface)] px-3 py-2.5 hover:border-[color-mix(in_srgb,var(--brand)_35%,var(--border))] hover:bg-[var(--surface-subtle)]"
        href="{{ node['url'] }}"
        data-graph-list-item
        data-graph-title="{{ node['title']|lower }}"
        ><span class="min-w-0"
          ><strong
            class="block overflow-hidden text-ellipsis whitespace-nowrap text-sm text-[var(--text-strong)]"
            >{{ node['title'] }}</strong
          ><small class="text-xs text-[var(--faint)]"
            >{{ node['section'] }}</small
          ></span
        ><span
          class="shrink-0 rounded-full border border-[var(--border)] px-2 py-1 text-[10px] text-[var(--muted)]"
          >{{ node['inbound'] }} in</span
        ></a
      >{% endfor %}
    </div>
  </section>
</article>
