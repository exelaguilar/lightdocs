{% macro icon(name, classes = '') %}
  <svg class="h-3 w-3 shrink-0 opacity-70 {{ classes }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    {% if name == 'home' %}
      <path d="M3 10.5 12 3l9 7.5"/><path d="M5 9.5V21h14V9.5"/>
    {% elseif name in ['server', 'proxmox'] %}
      <rect x="3" y="4" width="18" height="6" rx="1.5"/><rect x="3" y="14" width="18" height="6" rx="1.5"/><path d="M7 7h.01M7 17h.01"/>
    {% elseif name == 'guides' %}
      <path d="M4 5.5A2.5 2.5 0 0 1 6.5 3H11v16H6.5A2.5 2.5 0 0 0 4 21.5z"/><path d="M20 5.5A2.5 2.5 0 0 0 17.5 3H13v16h4.5a2.5 2.5 0 0 1 2.5 2.5z"/>
    {% else %}
      <path d="M3 6.5A1.5 1.5 0 0 1 4.5 5H9l2 2h8.5A1.5 1.5 0 0 1 21 8.5v9a1.5 1.5 0 0 1-1.5 1.5h-15A1.5 1.5 0 0 1 3 17.5z"/>
    {% endif %}
  </svg>
{% endmacro %}

{% macro tree(nodes, current, depth = 0) %}
  <ul class="m-0 list-none p-0{{ depth > 0 ? ' relative mb-[9px] ms-3 mt-[3px] ps-3 before:absolute before:inset-y-1 before:w-px before:bg-[var(--border)]' : '' }}" data-nav-list>
    {% for node in nodes %}
      {% set url = node['url']|default('#') %}
      {% set active = url == current %}
      <li class="my-px">
        {% if node['type']|default('page') == 'folder' %}
          {% set open = active or node['landing']|default(false) or not node['collapsed']|default(false) %}
          <details class="group" data-nav-folder="{{ url }}"{{ open ? ' open' : '' }}>
            <summary class="flex min-h-9 cursor-pointer list-none items-center gap-2 rounded-[var(--radius-sm)] px-[9px] py-[7px] text-sm font-[620] leading-[1.4] text-[var(--text)] hover:bg-[var(--surface-subtle)]">
              <span class="h-1.5 w-1.5 shrink-0 -rotate-45 border-b-[1.5px] border-r-[1.5px] border-current text-[var(--faint)]"></span>
              {% if node['landing']|default(false) %}<a class="min-w-0 flex-1 overflow-hidden text-ellipsis whitespace-nowrap" href="{{ url }}">{{ node['title'] }}</a>{% else %}<span class="min-w-0 overflow-hidden text-ellipsis">{{ node['title'] }}</span>{% endif %}
            </summary>
            {{ _self.tree(node['children']|default([]), current, depth + 1) }}
          </details>
        {% else %}
          <a class="flex min-h-9 items-center gap-2 rounded-[var(--radius-sm)] px-[9px] py-[7px] text-sm{{ active ? ' relative bg-[var(--brand-soft)] font-[620] text-[var(--brand-strong)]' : ' text-[var(--muted)]' }}" href="{{ url }}"{{ active ? ' aria-current="page"' : '' }}>
            <span class="min-w-0 overflow-hidden text-ellipsis">{{ node['title'] }}</span>
            {% if node['private']|default(false) %}<span class="ms-auto rounded-full border border-[var(--border)] px-[5px] py-[3px] text-[11px]">Private</span>{% elseif node['draft']|default(false) %}<span class="ms-auto rounded-full border border-[var(--border)] px-[5px] py-[3px] text-[11px]">Draft</span>{% endif %}
          </a>
        {% endif %}
      </li>
    {% endfor %}
  </ul>
{% endmacro %}
