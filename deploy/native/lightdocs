#!/usr/bin/env bash
set -euo pipefail

APP_ROOT="${LIGHTDOCS_APP_ROOT:-/opt/lightdocs}"
RELEASES_DIR="$APP_ROOT/releases"
CURRENT_LINK="$APP_ROOT/current"
PREVIOUS_LINK="$APP_ROOT/previous"
SITE_DIR="${LIGHTDOCS_SITE_DIR:-/var/lib/lightdocs}"
STATE_DIR="${LIGHTDOCS_STATE_DIR:-$SITE_DIR/var}"
ENV_FILE="${LIGHTDOCS_ENV_FILE:-/etc/lightdocs/lightdocs.env}"
BACKUP_DIR="${LIGHTDOCS_BACKUP_DIR:-/var/backups/lightdocs}"
REPOSITORY="${LIGHTDOCS_REPOSITORY:-exelaguilar/lightdocs}"
PHP_BIN="${LIGHTDOCS_PHP_BIN:-/usr/bin/php8.4}"
CLEANUP_PATHS=()
RESTORE_RESTART_FPM=0

cleanup() {
    local path
    for path in "${CLEANUP_PATHS[@]:-}"; do
        [[ -z "$path" || ! -e "$path" ]] || rm -rf "$path"
    done
    if [[ $RESTORE_RESTART_FPM -eq 1 ]]; then
        systemctl start php8.4-fpm >/dev/null 2>&1 || true
    fi
}
trap cleanup EXIT

if [[ -f /etc/lightdocs/installer.conf ]]; then
    # This file is root-owned installer configuration, never user content.
    # shellcheck disable=SC1091
    source /etc/lightdocs/installer.conf
fi

die() { echo "Error: $*" >&2; exit 1; }
need_root() { [[ $EUID -eq 0 ]] || die "This command must run as root."; }

ensure_layout() {
    mkdir -p "$RELEASES_DIR" "$SITE_DIR/content" "$SITE_DIR/public/uploads" "$STATE_DIR/cache" "$STATE_DIR/revisions" "$STATE_DIR/exports" "$BACKUP_DIR" "$(dirname "$ENV_FILE")"
    chown -R www-data:www-data "$SITE_DIR"
    chown root:www-data "$(dirname "$ENV_FILE")"
    chmod 0770 "$(dirname "$ENV_FILE")"
    if [[ -f "$ENV_FILE" ]]; then
        chown root:www-data "$ENV_FILE"
        chmod 0660 "$ENV_FILE"
    fi
}

run_docs() {
    local release="$1"
    shift
    runuser -u www-data -- env \
        LIGHTDOCS_SITE_DIR="$SITE_DIR" \
        LIGHTDOCS_STATE_DIR="$STATE_DIR" \
        LIGHTDOCS_ENV_FILE="$ENV_FILE" \
        "$PHP_BIN" "$release/bin/docs" "$@"
}

seed_site() {
    local release="$1"
    if [[ ! -f "$SITE_DIR/content/index.md" ]]; then
        cp -a "$release/resources/starter-site/content/." "$SITE_DIR/content/"
    fi
    if [[ ! -f "$SITE_DIR/.gitignore" ]]; then
        cp "$release/resources/starter-site/.gitignore" "$SITE_DIR/.gitignore"
    fi
    if [[ ! -f "$SITE_DIR/public/uploads/.gitkeep" ]]; then
        cp "$release/resources/starter-site/public/uploads/.gitkeep" "$SITE_DIR/public/uploads/.gitkeep"
    fi
    chown -R www-data:www-data "$SITE_DIR"
}

atomic_link() {
    local target="$1" link="$2" temporary="$APP_ROOT/.link-$$-$(basename "$link")"
    ln -s "$target" "$temporary"
    mv -Tf "$temporary" "$link"
}

install_managed_configs() {
    local release="$1"
    if [[ -d /etc/php/8.4/fpm/pool.d && -f "$release/deploy/native/php-fpm.conf" ]]; then
        install -m 0644 "$release/deploy/native/php-fpm.conf" /etc/php/8.4/fpm/pool.d/lightdocs.conf
    fi
    if [[ -d /etc/nginx/sites-available && -f "$release/deploy/native/nginx.conf" ]]; then
        install -m 0644 "$release/deploy/native/nginx.conf" /etc/nginx/sites-available/lightdocs
        ln -sfn /etc/nginx/sites-available/lightdocs /etc/nginx/sites-enabled/lightdocs
    fi
}

reload_services() {
    if systemctl is-active --quiet php8.4-fpm; then
        systemctl reload php8.4-fpm || return 1
    fi
    if systemctl is-active --quiet nginx; then
        nginx -t || return 1
        systemctl reload nginx || return 1
    fi
    return 0
}

check_http() {
    if ! systemctl is-active --quiet nginx; then return 0; fi
    local attempt
    for attempt in {1..10}; do
        if curl --fail --silent --show-error http://127.0.0.1/healthz >/dev/null; then return 0; fi
        sleep 1
    done
    return 1
}

download_release() {
    local requested="${1:-latest}" work="$2"
    local archive checksum tag
    archive="$work/lightdocs-release.tar.gz"
    checksum="$archive.sha256"
    if [[ -n "${LIGHTDOCS_ARCHIVE:-}" ]]; then
        cp "$LIGHTDOCS_ARCHIVE" "$archive"
        if [[ -n "${LIGHTDOCS_ARCHIVE_SHA256:-}" ]]; then
            printf '%s  %s\n' "$LIGHTDOCS_ARCHIVE_SHA256" "$(basename "$archive")" > "$checksum"
        elif [[ -f "$LIGHTDOCS_ARCHIVE.sha256" ]]; then
            cp "$LIGHTDOCS_ARCHIVE.sha256" "$checksum"
        else
            die "A local archive requires LIGHTDOCS_ARCHIVE_SHA256 or an adjacent .sha256 file."
        fi
    else
        if [[ "$requested" == "latest" ]]; then
            tag="latest/download"
        else
            requested="${requested#v}"
            [[ "$requested" =~ ^[0-9]+\.[0-9]+\.[0-9]+([.-][A-Za-z0-9.-]+)?$ ]] || die "Invalid release version: $requested"
            tag="download/v$requested"
        fi
        local base="${LIGHTDOCS_RELEASE_BASE_URL:-https://github.com/$REPOSITORY/releases}/$tag"
        curl --fail --silent --show-error --location "$base/lightdocs-release.tar.gz" --output "$archive"
        curl --fail --silent --show-error --location "$base/lightdocs-release.tar.gz.sha256" --output "$checksum"
    fi
    local expected
    expected="$(awk 'NR == 1 {print $1}' "$checksum")"
    [[ "$expected" =~ ^[a-fA-F0-9]{64}$ ]] || die "Release checksum is invalid."
    printf '%s  %s\n' "$expected" "$(basename "$archive")" > "$checksum"
    (cd "$work" && sha256sum --check --status "$(basename "$checksum")")
    if tar -tzf "$archive" | grep -Eq '(^/|(^|/)\.\.(/|$))'; then
        die "Release archive contains an unsafe path."
    fi
    printf '%s\n' "$archive"
}

update_release() {
    need_root
    local requested="${1:-latest}" work extract version target previous
    ensure_layout
    work="$(mktemp -d)"
    CLEANUP_PATHS+=("$work")
    extract="$work/extract"
    mkdir -p "$extract"
    local archive
    archive="$(download_release "$requested" "$work")"
    tar -xzf "$archive" -C "$extract"
    [[ -f "$extract/VERSION" && -f "$extract/bin/docs" ]] || die "Release archive is incomplete."
    version="$(tr -d '[:space:]' < "$extract/VERSION")"
    [[ "$version" =~ ^[0-9]+\.[0-9]+\.[0-9]+([.-][A-Za-z0-9.-]+)?$ ]] || die "Release contains an invalid VERSION."
    target="$RELEASES_DIR/$version"
    if [[ ! -d "$target" ]]; then
        mkdir -p "$target"
        cp -a "$extract/." "$target/"
    fi
    seed_site "$target"
    run_docs "$target" doctor
    run_docs "$target" validate
    run_docs "$target" index

    previous="$(readlink -f "$CURRENT_LINK" 2>/dev/null || true)"
    if [[ -n "$previous" && "$previous" != "$target" ]]; then
        atomic_link "$previous" "$PREVIOUS_LINK"
    fi
    atomic_link "$target" "$CURRENT_LINK"
    install_managed_configs "$target"
    if ! reload_services || ! check_http; then
        if [[ -n "$previous" && -d "$previous" ]]; then
            atomic_link "$previous" "$CURRENT_LINK"
            install_managed_configs "$previous"
            reload_services || true
        fi
        die "The HTTP health check failed; the previous release was restored."
    fi
    install -m 0755 "$target/deploy/native/lightdocs" /usr/local/sbin/lightdocs
    echo "Lightdocs is now at version $version."
}

rollback_release() {
    need_root
    local requested="${1:-}" target current
    if [[ -n "$requested" ]]; then
        requested="${requested#v}"
        target="$RELEASES_DIR/$requested"
    else
        target="$(readlink -f "$PREVIOUS_LINK" 2>/dev/null || true)"
    fi
    [[ -n "$target" && -d "$target" ]] || die "No rollback release is available."
    current="$(readlink -f "$CURRENT_LINK" 2>/dev/null || true)"
    run_docs "$target" doctor
    atomic_link "$target" "$CURRENT_LINK"
    [[ -z "$current" || "$current" == "$target" ]] || atomic_link "$current" "$PREVIOUS_LINK"
    install_managed_configs "$target"
    if ! reload_services || ! check_http; then
        if [[ -n "$current" && -d "$current" ]]; then
            atomic_link "$current" "$CURRENT_LINK"
            install_managed_configs "$current"
            reload_services || true
        fi
        die "Rollback target failed its health check; the original release was restored."
    fi
    echo "Rolled back to $(tr -d '[:space:]' < "$target/VERSION")."
}

create_backup() {
    need_root
    local destination="${1:-$BACKUP_DIR/lightdocs-$(date -u +%Y%m%dT%H%M%SZ).tar.gz}" stage
    ensure_layout
    stage="$(mktemp -d)"
    mkdir -p "$stage/site/public" "$stage/config"
    rsync -a "$SITE_DIR/content/" "$stage/site/content/"
    rsync -a "$SITE_DIR/public/uploads/" "$stage/site/public/uploads/"
    [[ ! -d "$SITE_DIR/.git" ]] || rsync -a "$SITE_DIR/.git/" "$stage/site/.git/"
    [[ ! -f "$SITE_DIR/.gitignore" ]] || cp "$SITE_DIR/.gitignore" "$stage/site/.gitignore"
    [[ ! -f "$ENV_FILE" ]] || cp "$ENV_FILE" "$stage/config/lightdocs.env"
    {
        printf 'format=1\n'
        printf 'created_at=%s\n' "$(date -u +%FT%TZ)"
        printf 'version=%s\n' "$(cat "$CURRENT_LINK/VERSION" 2>/dev/null || printf unknown)"
    } > "$stage/manifest"
    mkdir -p "$(dirname "$destination")"
    tar -C "$stage" -czf "$destination" .
    sha256sum "$destination" > "$destination.sha256"
    chmod 0600 "$destination" "$destination.sha256"
    rm -rf "$stage"
    echo "$destination"
}

restore_backup() {
    need_root
    local archive="${1:-}" work
    [[ -f "$archive" ]] || die "Provide an existing Lightdocs backup archive."
    if [[ -f "$archive.sha256" ]]; then
        local expected actual
        expected="$(awk 'NR == 1 {print $1}' "$archive.sha256")"
        actual="$(sha256sum "$archive" | awk '{print $1}')"
        [[ "$expected" =~ ^[a-fA-F0-9]{64}$ && "${expected,,}" == "$actual" ]] || die "Backup checksum verification failed."
    fi
    if tar -tzf "$archive" | grep -Eq '(^/|(^|/)\.\.(/|$))'; then die "Backup contains an unsafe path."; fi
    work="$(mktemp -d)"
    CLEANUP_PATHS+=("$work")
    tar -xzf "$archive" -C "$work"
    [[ -f "$work/manifest" && -d "$work/site/content" ]] || die "This is not a complete Lightdocs backup."
    local safety_backup
    safety_backup="$(create_backup)"
    echo "Created pre-restore backup: $safety_backup"
    if systemctl is-active --quiet php8.4-fpm; then
        RESTORE_RESTART_FPM=1
        systemctl stop php8.4-fpm
    fi
    rsync -a --delete "$work/site/content/" "$SITE_DIR/content/"
    mkdir -p "$SITE_DIR/public/uploads"
    rsync -a --delete "$work/site/public/uploads/" "$SITE_DIR/public/uploads/"
    if [[ -d "$work/site/.git" ]]; then rsync -a --delete "$work/site/.git/" "$SITE_DIR/.git/"; fi
    if [[ -f "$work/site/.gitignore" ]]; then cp "$work/site/.gitignore" "$SITE_DIR/.gitignore"; fi
    if [[ -f "$work/config/lightdocs.env" ]]; then install -o root -g www-data -m 0660 "$work/config/lightdocs.env" "$ENV_FILE"; fi
    chown -R www-data:www-data "$SITE_DIR"
    systemctl start php8.4-fpm
    RESTORE_RESTART_FPM=0
    run_docs "$CURRENT_LINK" doctor
    run_docs "$CURRENT_LINK" index
    reload_services
    check_http || die "Restore completed, but the HTTP health check failed."
    echo "Restore completed successfully."
}

uninstall_lightdocs() {
    need_root
    local purge="${1:-}"
    rm -f /etc/nginx/sites-enabled/lightdocs /etc/nginx/sites-available/lightdocs /etc/php/8.4/fpm/pool.d/lightdocs.conf
    reload_services
    [[ "$APP_ROOT" == "/opt/lightdocs" ]] || die "Refusing to remove a nonstandard application root automatically."
    rm -rf "$APP_ROOT"
    if [[ "$purge" == "--purge" ]]; then
        if [[ "${LIGHTDOCS_CONFIRM_PURGE:-}" != "YES" ]]; then
            die "Set LIGHTDOCS_CONFIRM_PURGE=YES with --purge to remove persistent content and configuration."
        fi
        [[ "$SITE_DIR" == "/var/lib/lightdocs" ]] || die "Refusing to purge a nonstandard site directory automatically."
        rm -rf "$SITE_DIR" /etc/lightdocs "$BACKUP_DIR"
    else
        echo "Persistent data remains in $SITE_DIR and configuration remains in /etc/lightdocs."
    fi
    rm -f /usr/local/sbin/lightdocs
    echo "Lightdocs application files were removed."
}

main() {
    local command="${1:-help}"
    shift || true
    case "$command" in
        doctor) run_docs "$CURRENT_LINK" doctor ;;
        version) run_docs "$CURRENT_LINK" version ;;
        update) update_release "${1:-latest}" ;;
        rollback) rollback_release "${1:-}" ;;
        backup) create_backup "${1:-}" ;;
        restore) restore_backup "${1:-}" ;;
        uninstall) uninstall_lightdocs "${1:-}" ;;
        help|-h|--help)
            echo "Usage: lightdocs {doctor|version|update [version]|rollback [version]|backup [path]|restore ARCHIVE|uninstall [--purge]}"
            ;;
        *) die "Unknown command: $command" ;;
    esac
}

if [[ "${BASH_SOURCE[0]}" == "$0" ]]; then
    main "$@"
fi
