{
  "name": "exelaguilar/lightdocs",
  "description": "A lightweight PHP and Markdown-first documentation platform.",
  "type": "project",
  "license": "MIT",
  "repositories": [
    {
      "type": "vcs",
      "url": "https://github.com/exelaguilar/tailwind-php.git"
    },
    {
      "type": "vcs",
      "url": "https://github.com/exelaguilar/tiny-mvc-framework.git"
    }
  ],
  "require": {
    "php": "^8.4",
    "ext-dom": "*",
    "ext-json": "*",
    "ext-mbstring": "*",
    "ext-pdo": "*",
    "ext-pdo_sqlite": "*",
    "exelaguilar/tiny-mvc-framework-private": "^0.9",
    "league/commonmark": "^2.8",
    "symfony/yaml": "^7.3 || ^8.0",
    "tailwindphp/tailwindphp": "dev-main",
    "tempest/highlight": "^2.0",
    "vlucas/phpdotenv": "^5.6"
  },
  "autoload": {
    "psr-4": {},
    "classmap": []
  },
  "scripts": {
    "docs:serve": "php -S 127.0.0.1:8080 -t upload upload/router.php",
    "docs:validate": "php bin/docs validate",
    "docs:build": "php bin/docs build build",
    "docs:test": "php tests/smoke.php",
    "docs:doctor": "php bin/docs doctor",
    "css:build": "php bin/build-css.php",
    "release:build": "bash deploy/release/build.sh",
    "release:build-windows": "powershell -ExecutionPolicy Bypass -File deploy/release/build.ps1"
  },
  "config": {
    "vendor-dir": "upload/vendor",
    "optimize-autoloader": true,
    "sort-packages": true
  }
}
