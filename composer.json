{
  "name": "exelaguilar/lightdocs",
  "description": "A lightweight PHP and Markdown-first documentation platform.",
  "type": "project",
  "license": "MIT",
  "repositories": [
    {
      "type": "vcs",
      "url": "https://github.com/exelaguilar/tailwind-php.git"
    },
    {
      "type": "vcs",
      "url": "https://github.com/exelaguilar/tiny-mvc-framework.git"
    }
  ],
  "require": {
    "php": "^8.4",
    "ext-dom": "*",
    "ext-json": "*",
    "ext-mbstring": "*",
    "ext-pdo": "*",
    "ext-pdo_sqlite": "*",
    "exelaguilar/tiny-mvc-framework-private": "^0.35",
    "league/commonmark": "^2.8",
    "symfony/yaml": "^7.3 || ^8.0",
    "tailwindphp/tailwindphp": "dev-main#b00a547e471dbc394d910efea3cdc0ae41452f2f",
    "tempest/highlight": "^2.0",
    "vlucas/phpdotenv": "^5.6"
  },
  "autoload": {
    "psr-4": {},
    "classmap": []
  },
  "scripts": {
    "docs:serve": "php -S 127.0.0.1:8080 -t upload upload/router.php",
    "docs:validate": "php bin/docs validate",
    "docs:build": "php bin/docs build build",
    "docs:test": [
      "@php tests/package_resolution.php",
      "@php tests/boot.php",
      "@php tests/kernel.php",
      "@php tests/extension_platform.php",
      "@php tests/extension_authorization.php",
      "@php tests/extension_policy.php",
      "@php tests/extension_lifecycle.php",
      "@php tests/lifecycle_harness.php",
      "@php tests/lifecycle.php",
      "@php tests/smoke.php"
    ],
    "docs:doctor": "php bin/docs doctor",
    "css:build": "php bin/build-css.php",
    "release:build": "bash deploy/release/build.sh",
    "release:build-windows": "powershell -ExecutionPolicy Bypass -File deploy/release/build.ps1"
  },
  "config": {
    "vendor-dir": "upload/vendor",
    "optimize-autoloader": true,
    "sort-packages": true
  }
}
